rules_version = '2';
// Padrão de pastas: mídia de cada igreja cliente sob `igrejas/{igrejaId}/`
// (membros, noticias, eventos, patrimonio, logo, etc.). Conteúdo institucional
// da Gestão YAHWEH (divulgação) não deve usar o prefixo `igrejas/`.
//
// Leitura pública: já coberta por regras explícitas (membros, notícias, eventos,
// patrimônio, logos, etc.). NÃO substitua este arquivo por um único
// `match /{allPaths=**} { allow read: if true; }` — isso expõe qualquer objeto
// futuro no bucket e, com a semântica OR do Storage, pode anular regras mais restritas.
//
// Deploy: na raiz do repo, `.\scripts\deploy_firebase_rules.ps1` (ver regra do projeto).
//
// Padrão Controle Total: write autenticado + limite de tamanho; MIME flexível (octet-stream / vazio).
// Ficheiro no Storage → URL no documento Firestore (sem fila pending_uploads).
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function fsUser() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function fsMembro(igrejaId) {
      return firestore.get(/databases/(default)/documents/igrejas/$(igrejaId)/membros/$(request.auth.uid));
    }

    function fsTenantUser(igrejaId) {
      return firestore.get(/databases/(default)/documents/igrejas/$(igrejaId)/users/$(request.auth.uid));
    }

    function fsIgreja(igrejaId) {
      return firestore.get(/databases/(default)/documents/igrejas/$(igrejaId));
    }

    function storageUserRole() {
      return isSignedIn() && fsUser().exists && fsUser().data.role is string
        ? fsUser().data.role : '';
    }

    function storageMemberRole(data) {
      return data.role is string ? data.role
        : (data.FUNCAO is string ? data.FUNCAO
        : (data.funcao is string ? data.funcao : ''));
    }

    function storageStaffRoleMatches(r) {
      return r == 'GESTOR' || r == 'gestor' || r == 'Gestor'
        || r == 'ADMIN' || r == 'ADM' || r == 'admin' || r == 'adm'
        || r == 'Adm' || r == 'Admin'
        || r == 'administrador' || r == 'administradora'
        || r == 'Administrador' || r == 'Administradora'
        || r == 'PASTOR' || r == 'pastor' || r == 'PASTORA' || r == 'pastora'
        || r == 'Pastor' || r == 'Pastora'
        || r == 'pastor_presidente' || r == 'PASTOR_PRESIDENTE'
        || r == 'pastor_auxiliar' || r == 'PASTOR_AUXILIAR' || r == 'Pastor Auxiliar'
        || r == 'ministerial' || r == 'pastor_auxiliar_ministerial'
        || r == 'SECRETARIO' || r == 'secretario' || r == 'Secretario'
        || r == 'SECRETÃRIO' || r == 'SecretÃ¡rio'
        || r == 'secretÃ¡ria' || r == 'Secretaria'
        || r == 'tesoureiro' || r == 'TESOUREIRO' || r == 'Tesoureiro'
        || r == 'tesouraria' || r == 'TESOURARIA' || r == 'Tesouraria'
        || r == 'MASTER' || r == 'master' || r == 'Master'
        || r == 'PRESBITERO' || r == 'presbitero' || r == 'PRESBITERA' || r == 'presbitera'
        || r == 'Presbitero' || r == 'Presbitera'
        || r == 'lider' || r == 'LIDER' || r == 'Lider'
        || r == 'lider_departamento' || r == 'LIDER_DEPARTAMENTO' || r == 'Lider Departamento'
        || r == 'lider_depto' || r == 'LIDER_DEPTO'
        || r == 'lider_grupo' || r == 'LIDER_GRUPO' || r == 'Lider grupo' || r == 'Lider Grupo'
        || r == 'lider_de_grupo' || r == 'LIDER_DE_GRUPO';
    }

    function storageTokenRole() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role : '';
    }

    function storageMuralPermissionList(perms) {
      return perms is list && perms.hasAny([
        'eventos', 'eventos_avisos_edicao', 'mural_avisos_edicao'
      ]);
    }

    function storageTenantUserMuralEdit(igrejaId) {
      return fsTenantUser(igrejaId).exists && (
        (fsTenantUser(igrejaId).data.permissions is list
          && storageMuralPermissionList(fsTenantUser(igrejaId).data.permissions))
        || (fsTenantUser(igrejaId).data.roles is list
          && storageMuralPermissionList(fsTenantUser(igrejaId).data.roles))
      );
    }

    function storageGestorEmailMatches(igrejaId) {
      return isSignedIn()
        && request.auth.token.email != null
        && fsIgreja(igrejaId).exists
        && (
          fsIgreja(igrejaId).data.gestorEmail == request.auth.token.email
          || fsIgreja(igrejaId).data.email == request.auth.token.email
        );
    }

    function isChurchMember(igrejaId) {
      return isSignedIn() && (
        (fsUser().exists && (
          fsUser().data.igrejaId == igrejaId
          || fsUser().data.tenantId == igrejaId
          || fsUser().data.churchId == igrejaId
        ))
        || request.auth.token.igrejaId == igrejaId
        || request.auth.token.tenantId == igrejaId
        || request.auth.token.churchId == igrejaId
        || fsMembro(igrejaId).exists
        || fsTenantUser(igrejaId).exists
        || storageGestorEmailMatches(igrejaId)
      );
    }

    /// Staff: gestor, admin, pastor, secretário, tesoureiro, líder (+ e-mail gestor + permissões mural).
    function isChurchStaffWriter(igrejaId) {
      return isSignedIn() && (
        storageStaffRoleMatches(storageUserRole())
        || storageStaffRoleMatches(storageTokenRole())
        || (fsTenantUser(igrejaId).exists
          && storageStaffRoleMatches(storageMemberRole(fsTenantUser(igrejaId).data)))
        || (fsMembro(igrejaId).exists
          && storageStaffRoleMatches(storageMemberRole(fsMembro(igrejaId).data)))
        || storageGestorEmailMatches(igrejaId)
        || (isChurchMember(igrejaId) && storageTenantUserMuralEdit(igrejaId))
      );
    }

    // Imagem ou vídeo + tipos que Flutter/Web enviam (octet-stream / vazio)
    function mediaImageVideoOrBlob() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('video/.*')
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType == '';
    }

    /// Chat: fotos, vídeos, áudio (voz / ficheiro), PDF, Office, ZIP/RAR, APK, etc.
    /// iOS/Android podem enviar MIME atípico (ex.: audio/x-caf, image/heic, video/quicktime).
    function chatMediaOrBlob() {
      return mediaImageVideoOrBlob()
        || request.resource.contentType == 'image/webp'
        || request.resource.contentType.matches('audio/.*')
        || request.resource.contentType.matches('application/pdf')
        || request.resource.contentType.matches('application/msword')
        || request.resource.contentType == 'application/vnd.ms-excel'
        || request.resource.contentType == 'application/vnd.ms-powerpoint'
        || request.resource.contentType.matches('application/vnd.ms-.*')
        || request.resource.contentType ==
             'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
        || request.resource.contentType ==
             'application/vnd.openxmlformats-officedocument.presentationml.presentation'
        || request.resource.contentType.matches(
             'application/vnd.openxmlformats-officedocument.*')
        || request.resource.contentType.matches('text/.*')
        || request.resource.contentType.matches('application/rtf')
        || request.resource.contentType == 'audio/x-caf'
        || request.resource.contentType == 'audio/amr'
        || request.resource.contentType == 'audio/x-m4a'
        || request.resource.contentType == 'image/heic'
        || request.resource.contentType == 'image/heif'
        || request.resource.contentType == 'video/quicktime'
        || request.resource.contentType == 'video/x-m4v'
        || request.resource.contentType == 'application/zip'
        || request.resource.contentType == 'application/vnd.rar'
        || request.resource.contentType == 'application/x-rar-compressed'
        || request.resource.contentType == 'application/x-7z-compressed'
        || request.resource.contentType == 'application/java-archive'
        || request.resource.contentType ==
             'application/vnd.android.package-archive';
    }

    /// Upload autenticado (mobile): não bloquear por MIME quando o cliente envia octet-stream ou tipo vazio.
    function authMediaWriteMax(maxBytes) {
      return request.auth != null
        && request.resource != null
        && request.resource.size < maxBytes;
    }

    // Só imagem (foto de membro, logo, patrimônio) + octet-stream / vazio
    function photoImageOrBlob() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType == 'image/webp'
        || request.resource.contentType == 'image/heic'
        || request.resource.contentType == 'image/heif'
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType == '';
    }

    // Cadastro público (web): `membros/fotos/{id}.webp` ou legado `foto_perfil.jpg`
    function isMemberCanonicalProfilePhotoPath(p) {
      return p.matches('^fotos/[^/]+\\.webp$')
        || p.matches('^thumbs/[^/]+\\.webp$')
        || p.matches('^[^/]+/foto_perfil\\.jpg$');
    }

    // Comprovantes: imagem ou PDF + blob
    function comprovanteOrBlob() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('application/pdf')
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType == '';
    }

    function pkcs12OrBlob() {
      return request.resource.contentType == 'application/x-pkcs12'
        || request.resource.contentType == 'application/pkcs12'
        || request.resource.contentType == 'application/octet-stream';
    }

    function publicMediaPdfOrBlob() {
      return request.resource.contentType.matches('video/.*')
        || request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('application/pdf')
        || request.resource.contentType == 'application/octet-stream'
        || request.resource.contentType == '';
    }

    // Upload público de foto de membro (cadastro sem login) — sem vídeo
    match /members/{tenantId}/{fileName} {
      allow write: if request.auth == null
        && request.resource.size < 15 * 1024 * 1024
        && photoImageOrBlob();
      allow read: if true;
    }

    // Fotos de membros: membro da igreja (auth) OU cadastro público sem sessão (foto canónica só)
    match /igrejas/{igrejaId}/membros/{path=**} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024
        && photoImageOrBlob()
        && (
          isMemberCanonicalProfilePhotoPath(path)
          || (isChurchMember(igrejaId) && (
            isChurchStaffWriter(igrejaId)
            || path.matches('^fotos/.*')
            || path.matches('^thumbs/.*')
          ))
        );
    }

    // Certificado digital A1 (PKCS#12) — só staff
    match /igrejas/{igrejaId}/certificados_gestor/{fileName} {
      allow read: if isChurchStaffWriter(igrejaId);
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 10 * 1024 * 1024
        && pkcs12OrBlob();
    }

    // Logo na raiz da igreja — só staff
    match /igrejas/{igrejaId}/{fileName} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 25 * 1024 * 1024
        && photoImageOrBlob();
    }

    // Identidade: logo, assinatura — só staff
    match /igrejas/{igrejaId}/configuracoes/{fileName} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 15 * 1024 * 1024
        && photoImageOrBlob();
    }

    // Foto do gestor — só staff
    match /igrejas/{igrejaId}/gestor/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 20 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /noticias/{tenantId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /departamentos/{tenantId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /patrimonio/{tenantId}/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    match /igrejas/{igrejaId}/comprovantes/{fileName} {
      allow read: if isChurchMember(igrejaId);
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 15 * 1024 * 1024
        && comprovanteOrBlob();
    }

    // Financeiro — comprovantes: só staff (gestor, pastor, secretário, tesoureiro)
    match /igrejas/{igrejaId}/financeiro/{path=**} {
      allow read: if isChurchMember(igrejaId);
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 15 * 1024 * 1024
        && comprovanteOrBlob();
    }

    // Mural eventos/avisos — só staff (+ MIME)
    match /igrejas/{igrejaId}/eventos/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && authMediaWriteMax(120 * 1024 * 1024)
        && mediaImageVideoOrBlob();
    }

    match /igrejas/{igrejaId}/noticias/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && authMediaWriteMax(120 * 1024 * 1024)
        && mediaImageVideoOrBlob();
    }

    match /igrejas/{igrejaId}/avisos/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && authMediaWriteMax(120 * 1024 * 1024)
        && mediaImageVideoOrBlob();
    }

    // Fotos de departamentos — só staff
    match /igrejas/{igrejaId}/departamentos/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 15 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /tenants/{tenantId}/media/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // Chat igreja — qualquer membro da igreja (texto, foto, PDF, áudio, ficheiros)
    match /igrejas/{igrejaId}/chat_media/{path=**} {
      allow read: if isChurchMember(igrejaId);
      allow write: if isChurchMember(igrejaId)
        && request.resource.size < 200 * 1024 * 1024
        && chatMediaOrBlob();
    }

    // Figurinhas do chat — só staff
    match /igrejas/{igrejaId}/chat_stickers/{path=**} {
      allow read: if isChurchMember(igrejaId);
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 8 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /eventos/{eventoId}/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    match /certificado_logos/{tenantId}/{fileName} {
      allow read: if true;
      allow write: if isChurchStaffWriter(tenantId)
        && request.resource.size < 10 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /carteira_logos/{tenantId}/{fileName} {
      allow read: if true;
      allow write: if isChurchStaffWriter(tenantId)
        && request.resource.size < 10 * 1024 * 1024
        && photoImageOrBlob();
    }

    // Cartão de membro — logo dedicada (padrão: igrejas/{id}/cartao_membro/; legado: carteira_logos/).
    match /igrejas/{igrejaId}/cartao_membro/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 10 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /igrejas/{igrejaId}/certificados/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 25 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /igrejas/{igrejaId}/patrimonio/{path=**} {
      allow read: if true;
      allow write: if isChurchStaffWriter(igrejaId)
        && request.resource.size < 20 * 1024 * 1024
        && photoImageOrBlob();
    }

    // Uploads genéricos — membro da igreja (chat legado) ou staff
    match /igrejas/{igrejaId}/uploads/{path=**} {
      allow read: if isChurchMember(igrejaId);
      allow write: if isChurchMember(igrejaId)
        && request.resource.size < 300 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('audio/.*')
          || request.resource.contentType.matches('text/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/octet-stream'
          || request.resource.contentType == ''
          || request.resource.contentType.matches('application/.*')
        );
    }

    // Divulgação Gestão YAHWEH (`public/gestao_yahweh/...`). Em DELETE, `request.resource` é nulo —
    // a regra antiga só com `request.resource.size` bloqueava a exclusão pelo painel master.
    match /public/{path=**} {
      allow read: if true;
      allow delete: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 200 * 1024 * 1024
        && publicMediaPdfOrBlob();
    }

    // Demais pastas sob igrejas/{id}/... (eventos, notícias, avisos, configuracoes, gestor já cobertos acima).
    match /igrejas/{igrejaId}/{seg}/{rest=**} {
      allow read: if seg != 'certificados_gestor';
      allow write: if isChurchStaffWriter(igrejaId)
        && seg != 'eventos'
        && seg != 'noticias'
        && seg != 'avisos'
        && seg != 'configuracoes'
        && seg != 'gestor'
        && seg != 'chat_media'
        && seg != 'chat_stickers'
        && seg != 'departamentos'
        && seg != 'uploads'
        && seg != 'patrimonio'
        && seg != 'certificados'
        && seg != 'cartao_membro'
        && seg != 'comprovantes'
        && seg != 'financeiro'
        && seg != 'certificados_gestor'
        && seg != 'membros'
        && request.resource.size < 10 * 1024 * 1024
        && photoImageOrBlob();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
