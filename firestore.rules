rules_version = '2';
// Deploy â€” membros: indisponibilidade escala por e-mail (campos dedicados) + leitura sÃ³ na prÃ³pria igreja (+ operador global); CPF pÃºblico via Cloud Function.
// Operador global (multi-tenant): e-mail raihom@gmail.com OU CPF 94536368191 em users/{uid} OU documento admins/{uid}.
// ADM/gestor/pastor **da igreja** ficam isolados ao tenant (sameChurch / canAccessTenant); nÃ£o recebem bypass por role() ADM/MASTER no doc users.
//
// Blindagem offline-first (2026-06): paths canÃ³nicos igrejas/{churchId}/â€¦ â€” chat em chats/{threadId}/messages;
// create membros exige canAccessTenant + staff; delete/aprovaÃ§Ã£o via canStaffEditAnyMemberRecord (pastor/admin/secretÃ¡rio/tesoureiro);
// delete mensagem grupo: autor, pastoral/gestÃ£o ou lÃ­der do departamento (leaderCpfs no doc departamentos).
//
// GravaÃƒÂ§ÃƒÂ£o simples (padrÃƒÂ£o Controle Total): ficheiros Ã¢â€ â€™ Firebase Storage (putData); metadados Ã¢â€ â€™ coleÃƒÂ§ÃƒÂµes de negÃƒÂ³cio.
// `igrejas/{id}/pending_uploads` descontinuada no cliente â€” sÃ³ leitura/delete para limpar jobs antigos.
// ColeÃ§Ã£o raiz `pendingUploads` legada â€” bloqueada (migrar para subcoleÃ§Ã£o por igreja).
service cloud.firestore {
  match /databases/{database}/documents {

    // â”€â”€ Performance (2026-06): custom claims (request.auth.token) primeiro; get()/exists() sÃ³ fallback.
    // Backend: gravar role + tenantId + cpf nos claims no login â†’ zero leituras Firestore por request.

    function isSignedIn() { return request.auth != null; }
    function isMasterEmail() { return isSignedIn() && request.auth.token.email == 'raihom@gmail.com'; }

    function authUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function tenantUserDocPath(tenantId) {
      return /databases/$(database)/documents/igrejas/$(tenantId)/users/$(request.auth.uid);
    }
    function membroDocPath(tenantId, memberId) {
      return /databases/$(database)/documents/igrejas/$(tenantId)/membros/$(memberId);
    }
    function igrejaDocPath(tenantId) {
      return /databases/$(database)/documents/igrejas/$(tenantId);
    }

    function tokenString(key) {
      return isSignedIn() && (key in request.auth.token) && request.auth.token[key] is string
        ? request.auth.token[key] : '';
    }
    function tokenTenantIdFast() {
      let ig = tokenString('igrejaId');
      return ig.size() > 0 ? ig
        : (tokenString('tenantId').size() > 0 ? tokenString('tenantId') : tokenString('churchId'));
    }
    function tokenRoleFast() { return tokenString('role'); }
    function tokenCpf11Fast() {
      let c = tokenString('cpf');
      return c.matches('^[0-9]{11}$') ? c
        : (tokenString('cpfDigits').matches('^[0-9]{11}$') ? tokenString('cpfDigits') : '');
    }
    function tokenMemberDocIdFast() {
      let m = tokenString('memberDocId');
      return m.size() > 0 ? m : tokenString('member_doc_id');
    }
    function tokenTenantMatches(tenantId) {
      return isSignedIn() && (
        tokenString('igrejaId') == tenantId
        || tokenString('tenantId') == tenantId
        || tokenString('churchId') == tenantId
        || tokenString('churchCanonicalId') == tenantId
        || tokenString('canonicalTenantId') == tenantId
      );
    }
    function tokenHasModulePermission(moduleKey) {
      return isSignedIn()
        && (request.auth.token.permissions is list)
        && request.auth.token.permissions.hasAny([moduleKey]);
    }

    function masterCpfDigits() { return '94536368191'; }
    function cpf11FromUserData(d) {
      let c1 = d.get('cpf', '');
      let c2 = d.get('CPF', '');
      let c3 = d.get('linkedCpf', '');
      let c4 = d.get('cpfDigits', '');
      let c5 = d.get('CPF_DIGITS', '');
      return c1.matches('^[0-9]{11}$') ? c1
        : (c2.matches('^[0-9]{11}$') ? c2
        : (c3.matches('^[0-9]{11}$') ? c3
        : (c4.matches('^[0-9]{11}$') ? c4
        : (c5.matches('^[0-9]{11}$') ? c5 : ''))));
    }
    function cpf11ForAuth(userData) {
      let tc = tokenCpf11Fast();
      return tc.size() == 11 ? tc : cpf11FromUserData(userData);
    }

    /// ReforÃ§o ao e-mail: mesmo CPF que [AppConstants.productMasterCpfDigits] no doc users (formatos comuns).
    function userIsProductMasterByCpf() {
      let p = authUserDocPath();
      return tokenCpf11Fast() == masterCpfDigits()
        || (exists(p) && (
          cpf11FromUserData(get(p).data) == masterCpfDigits()
          || get(p).data.get('linkedCpf', '') == masterCpfDigits()
          || get(p).data.get('cpf', '') == '945.363.681-91'
        ));
    }
    function isPlatformOperator() {
      return isSignedIn() && (
        isMasterEmail()
        || userIsProductMasterByCpf()
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function roleFromUsersRolesList(roles) {
      return roles is list && roles.hasAny(['MASTER', 'master']) ? 'MASTER'
        : (roles is list && roles.hasAny(['ADMIN', 'ADM', 'admin', 'adm', 'Adm', 'Admin']) ? 'ADM'
        : (roles is list && roles.hasAny(['GESTOR', 'gestor', 'Gestor']) ? 'GESTOR' : ''));
    }
    function roleFromUserData(d) {
      let singular = d.get('role', '');
      return singular.size() > 0 ? singular : roleFromUsersRolesList(d.get('roles', []));
    }
    function role() {
      let tr = tokenRoleFast();
      return tr.size() > 0 ? tr
        : (isSignedIn() && exists(authUserDocPath()) ? roleFromUserData(get(authUserDocPath()).data) : '');
    }
    /// Legado: nome conservado; significado = operador global (e-mail/CPF/admins), **sem** role MASTER/ADM no cadastro users.
    function isMaster() { return isPlatformOperator(); }
    function adminRoleVariants() {
      return ['ADM', 'ADMIN', 'adm', 'admin', 'Adm', 'Admin', 'administrador', 'administradora', 'Administrador', 'Administradora'];
    }
    function isAdm() {
      let r = role();
      return isSignedIn() && r.size() > 0 && adminRoleVariants().hasAny([r]);
    }
    // Painel master YAHWEH (vendas, licenÃ§as, analytics global): sÃ³ operador de plataforma â€” nÃ£o ADM local da igreja.
    function isAdminPanel() { return isSignedIn() && isMaster(); }

    function userTenantFromData(d) {
      let ig = d.get('igrejaId', '');
      return ig.size() > 0 ? ig : d.get('tenantId', '');
    }
    function userBoundTenantId() {
      let tt = tokenTenantIdFast();
      return tt.size() > 0 ? tt
        : (isSignedIn() && exists(authUserDocPath()) ? userTenantFromData(get(authUserDocPath()).data) : '');
    }
    function userDocMatchesTenant(tenantId) {
      return tokenTenantMatches(tenantId)
        || (isSignedIn() && exists(authUserDocPath()) && tenantIdMatchesUserData(tenantId, get(authUserDocPath()).data));
    }
    function tenantIdMatchesUserData(tenantId, d) {
      return d.get('igrejaId', '') == tenantId
        || d.get('tenantId', '') == tenantId
        || d.get('churchId', '') == tenantId
        || d.get('churchCanonicalId', '') == tenantId
        || d.get('canonicalTenantId', '') == tenantId;
    }

    function bpcCanonicalId() { return 'igreja_o_brasil_para_cristo_jardim_goiano'; }
    function isBpcLegacyTenantId(id) {
      return id == 'brasilparacristo' || id == 'brasilparacristo_sistema'
        || id == 'iobpc-jardim-goiano' || id == 'o-brasil-cristo-jardim-goiano';
    }
    function bpcClusterMatches(tenantId) {
      let bound = userBoundTenantId();
      return isSignedIn() && (
        (tenantId == bpcCanonicalId() && (isBpcLegacyTenantId(bound) || tokenTenantMatches(bpcCanonicalId()) || isBpcLegacyTenantId(tokenTenantIdFast())))
        || (isBpcLegacyTenantId(tenantId) && (bound == bpcCanonicalId() || tokenString('igrejaId') == bpcCanonicalId() || tokenString('tenantId') == bpcCanonicalId()))
      );
    }
    function sameChurch(tenantId) {
      let bound = userBoundTenantId();
      return isSignedIn() && (
        bound == tenantId
        || tokenTenantMatches(tenantId)
        || userDocMatchesTenant(tenantId)
        || bpcClusterMatches(tenantId)
      );
    }

    function manageChurchRoleVariants() {
      return ['ADMIN', 'ADM', 'GESTOR', 'MASTER', 'admin', 'adm', 'gestor', 'master',
        'Gestor', 'Master', 'Admin', 'Adm', 'administrador', 'administradora', 'Administrador', 'Administradora'];
    }
    function canManageChurch() {
      let r = role();
      return isSignedIn() && r.size() > 0 && manageChurchRoleVariants().hasAny([r]);
    }
    function treasurerRoleVariants() {
      return ['TESOUREIRO', 'tesoureiro', 'Tesoureiro', 'TESOURARIA', 'tesouraria', 'Tesouraria'];
    }
    function isTreasurer() {
      let r = role();
      return isSignedIn() && r.size() > 0 && treasurerRoleVariants().hasAny([r]);
    }
    function pastorOnlyRoleVariants() {
      return ['PASTOR', 'pastor', 'PASTORA', 'pastora', 'Pastor', 'Pastora',
        'pastor_presidente', 'PASTOR_PRESIDENTE', 'Pastor Presidente', 'pastora_presidente',
        'pastor_auxiliar', 'PASTOR_AUXILIAR', 'Pastor Auxiliar',
        'ministerial', 'pastor_auxiliar_ministerial'];
    }
    function isPastorOnlyRole() {
      let r = role();
      return isSignedIn() && r.size() > 0 && pastorOnlyRoleVariants().hasAny([r]);
    }
    function isFinanceExclusiveReader(tenantId) {
      return isMaster() || (canAccessTenant(tenantId) && (isPastorOnlyRole() || isTreasurer()));
    }
    function isCorporateModuleReader(tenantId) {
      return isMaster() || (canAccessTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatMuralRole() || isTreasurer()));
    }
    function deptLeaderRoleVariants() {
      return ['lider', 'LIDER', 'Lider', 'lÃƒÂ­der', 'LÃƒÂ­der', 'LÃƒÂDER',
        'lider_departamento', 'LIDER_DEPARTAMENTO', 'Lider Departamento',
        'lider_depto', 'LIDER_DEPTO', 'lider_de_departamento', 'lider_ministerio',
        'LÃƒÂ­der de Departamento', 'lÃƒÂ­der de departamento',
        'lider_grupo', 'LIDER_GRUPO', 'Lider grupo', 'Lider Grupo',
        'LÃƒÂ­der de grupo', 'lÃƒÂ­der de grupo', 'Lider de grupo', 'LIDER DE GRUPO', 'lider de grupo',
        'lider_de_grupo', 'LIDER_DE_GRUPO'];
    }
    function isDepartmentLeaderRole() {
      let r = role();
      return r.size() > 0 && deptLeaderRoleVariants().hasAny([r]);
    }
    function pastorAuxiliarRoleVariants() {
      return ['pastor_auxiliar', 'PASTOR_AUXILIAR', 'Pastor Auxiliar', 'ministerial', 'pastor_auxiliar_ministerial'];
    }
    function isPastorAuxiliarRole() {
      let r = role();
      return r.size() > 0 && pastorAuxiliarRoleVariants().hasAny([r]);
    }
    function canWriteIgrejaDepartamentos(tenantId) {
      return isAdminPanel() || canWriteTenant(tenantId)
        || (canAccessTenant(tenantId) && isPastoralOrSecretariatRole())
        || (canAccessTenant(tenantId) && isTreasurer())
        || (canAccessTenant(tenantId) && isDepartmentLeaderRole())
        || (canAccessTenant(tenantId) && isPastorAuxiliarRole())
        || (canAccessTenant(tenantId) && hasTenantModulePermission(tenantId, 'departamentos'));
    }
    function canPost() { return canManageChurch(); }

    function emailMatchesTenant(tenantId) {
      return isSignedIn() && request.auth.token.email != null && exists(igrejaDocPath(tenantId))
        && (get(igrejaDocPath(tenantId)).data.get('email', '') == request.auth.token.email
            || get(igrejaDocPath(tenantId)).data.get('gestorEmail', '') == request.auth.token.email);
    }

    function membroDocAuthMatches(d) {
      return d.get('authUid', '') == request.auth.uid || d.get('firebaseUid', '') == request.auth.uid;
    }
    function memberDocIdFromUserData(d) {
      let m = d.get('memberDocId', '');
      return m.size() > 0 ? m : d.get('member_doc_id', '');
    }
    function memberDocIdLinksAuthToMembroFiltered(tenantId, d, requireMural, requireStaff) {
      let fromDoc = memberDocIdFromUserData(d);
      let chosen = fromDoc.size() > 0 ? fromDoc : tokenMemberDocIdFast();
      let p = membroDocPath(tenantId, chosen);
      return chosen.size() > 0 && exists(p)
        && membroDocAuthMatches(get(p).data)
        && (!requireMural || memberMembroDataAllowsMural(get(p).data))
        && (!requireStaff || staffMembroDataAllows(get(p).data));
    }
    function memberDocIdLinksAuthToMembro(tenantId, d) {
      return memberDocIdLinksAuthToMembroFiltered(tenantId, d, false, false);
    }
    function memberDocIdLinksAuthToMembroMural(tenantId, d) {
      return memberDocIdLinksAuthToMembroFiltered(tenantId, d, true, false);
    }
    function memberDocIdLinksAuthToMembroStaff(tenantId, d) {
      return memberDocIdLinksAuthToMembroFiltered(tenantId, d, false, true);
    }
    function cpf11MembroDocLinksAuthFiltered(tenantId, d, requireMural, requireStaff) {
      let cpf = cpf11ForAuth(d);
      let p = membroDocPath(tenantId, cpf);
      return cpf.size() == 11 && exists(p)
        && membroDocAuthMatches(get(p).data)
        && (!requireMural || memberMembroDataAllowsMural(get(p).data))
        && (!requireStaff || staffMembroDataAllows(get(p).data));
    }
    function cpf11MembroDocLinksAuth(tenantId, d) {
      return cpf11MembroDocLinksAuthFiltered(tenantId, d, false, false);
    }
    function cpf11MembroDocLinksAuthMural(tenantId, d) {
      return cpf11MembroDocLinksAuthFiltered(tenantId, d, true, false);
    }
    function cpf11MembroDocLinksAuthStaff(tenantId, d) {
      return cpf11MembroDocLinksAuthFiltered(tenantId, d, false, true);
    }

    function memberLinkedFromUserDoc(tenantId, d) {
      return memberDocIdLinksAuthToMembro(tenantId, d) || cpf11MembroDocLinksAuth(tenantId, d);
    }
    /// Membro cadastrado na igreja (doc por UID ou por CPF 11 dÃ­gitos vinculado ao authUid).
    /// Evita bloqueio de gravaÃ§Ã£o para quem estÃ¡ ativo em `membros`, mas sem espelho completo em `users`.
    /// Inclui `memberDocId` / `linkedCpf` / `cpfDigits` no `users` (doc `membros` muitas vezes com id = CPF).
    function memberLinkedToTenant(tenantId) {
      return isSignedIn() && (
        exists(membroDocPath(tenantId, request.auth.uid))
        || (exists(authUserDocPath()) && memberLinkedFromUserDoc(tenantId, get(authUserDocPath()).data))
      );
    }

    function canAccessTenant(tenantId) {
      return isMaster() || sameChurch(tenantId) || emailMatchesTenant(tenantId)
        || exists(tenantUserDocPath(tenantId))
        || memberLinkedToTenant(tenantId);
    }

    function requesterOwnsMemberDoc(tenantId, memberId) {
      let p = membroDocPath(tenantId, memberId);
      return isSignedIn() && exists(p) && (
        memberId == request.auth.uid
        || membroDocAuthMatches(get(p).data)
        || (exists(authUserDocPath()) && memberDocIdFromUserData(get(authUserDocPath()).data) == memberId
          && membroDocAuthMatches(get(p).data))
        || (exists(authUserDocPath()) && cpf11MembroDocLinksAuth(tenantId, get(authUserDocPath()).data)
          && memberId.matches('^[0-9]{11}$'))
      );
    }
    function canApprovePendingMemberRecord(tenantId) {
      return isMaster() || canAccessAprovacoesTenant(tenantId) || canStaffEditAnyMemberRecord(tenantId)
        || (canAccessTenant(tenantId) && isDepartmentLeaderRole());
    }
    function canStaffEditAnyMemberRecord(tenantId) {
      return isMaster() || isAdminPanel() || canWriteTenant(tenantId)
        || (canAccessTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatRole() || isPastorAuxiliarRole() || isTreasurer()))
        || (emailMatchesTenant(tenantId) && (isPastoralOrSecretariatRole() || isPastorAuxiliarRole() || isTreasurer()));
    }

    function muralRolesArrayMatches(roles) {
      return roles is list && roles.hasAny([
        'GESTOR', 'gestor', 'Gestor', 'ADMIN', 'ADM', 'admin', 'adm', 'Adm', 'Admin',
        'administrador', 'administradora', 'Administrador', 'Administradora',
        'PASTOR', 'pastor', 'PASTORA', 'pastora', 'Pastor', 'Pastora',
        'pastor_presidente', 'PASTOR_PRESIDENTE', 'Pastor Presidente', 'pastora_presidente',
        'pastor_auxiliar', 'PASTOR_AUXILIAR', 'Pastor Auxiliar', 'ministerial', 'pastor_auxiliar_ministerial',
        'SECRETARIO', 'secretario', 'SecretÃƒÂ¡rio', 'SECRETÃƒÂRIO', 'Secretario', 'secretÃƒÂ¡ria', 'Secretaria',
        'lider', 'LIDER', 'Lider', 'lÃƒÂ­der', 'LÃƒÂDER', 'LÃƒÂ­der',
        'lider_departamento', 'LIDER_DEPARTAMENTO', 'Lider Departamento', 'lider_depto', 'LIDER_DEPTO',
        'lider_de_departamento', 'lider_ministerio', 'LÃƒÂ­der de Departamento', 'lÃƒÂ­der de departamento',
        'lider_grupo', 'LIDER_GRUPO', 'Lider grupo', 'Lider Grupo',
        'LÃƒÂ­der de grupo', 'lÃƒÂ­der de grupo', 'Lider de grupo', 'LIDER DE GRUPO', 'lider de grupo',
        'lider_de_grupo', 'LIDER_DE_GRUPO',
        'tesoureiro', 'TESOUREIRO', 'Tesoureiro', 'tesouraria', 'TESOURARIA', 'Tesouraria'
      ]);
    }
    function muralRoleFromRolesArrays(tenantId) {
      let rootRoles = exists(authUserDocPath()) && get(authUserDocPath()).data.roles is list
        ? get(authUserDocPath()).data.roles : [];
      let tenantRoles = exists(tenantUserDocPath(tenantId)) && get(tenantUserDocPath(tenantId)).data.roles is list
        ? get(tenantUserDocPath(tenantId)).data.roles : [];
      return muralRolesArrayMatches(rootRoles) || muralRolesArrayMatches(tenantRoles);
    }
    function muralSingleRoleAllowsMural(r) {
      return r.size() > 0 && muralRolesArrayMatches([r]);
    }
    function muralRoleFromMemberDoc(tenantId) {
      let byUid = membroDocPath(tenantId, request.auth.uid);
      return (exists(byUid) && memberMembroDataAllowsMural(get(byUid).data))
        || (exists(authUserDocPath()) && cpf11MembroDocLinksAuthMural(tenantId, get(authUserDocPath()).data));
    }
    function muralRoleFromTenantUserDoc(tenantId) {
      let p = tenantUserDocPath(tenantId);
      return exists(p) && memberMembroDataAllowsMural(get(p).data);
    }
    function muralRoleFromLinkedMemberDoc(tenantId) {
      return exists(authUserDocPath()) && (
        memberDocIdLinksAuthToMembroMural(tenantId, get(authUserDocPath()).data)
        || cpf11MembroDocLinksAuthMural(tenantId, get(authUserDocPath()).data)
      );
    }
    function deptLeaderRolesArrayMatches(roles) {
      return roles is list && roles.hasAny(deptLeaderRoleVariants());
    }
    function deptLeaderFromRolesArrays(tenantId) {
      let rootRoles = exists(authUserDocPath()) && get(authUserDocPath()).data.roles is list
        ? get(authUserDocPath()).data.roles : [];
      let tenantRoles = exists(tenantUserDocPath(tenantId)) && get(tenantUserDocPath(tenantId)).data.roles is list
        ? get(tenantUserDocPath(tenantId)).data.roles : [];
      return deptLeaderRolesArrayMatches(rootRoles) || deptLeaderRolesArrayMatches(tenantRoles);
    }
    function financeDocReadBySubjectMember(tenantId) {
      return isSignedIn()
        && resource.data.get('memberDocId', '').size() > 0
        && exists(membroDocPath(tenantId, resource.data.memberDocId))
        && get(membroDocPath(tenantId, resource.data.memberDocId)).data.get('authUid', '') == request.auth.uid;
    }
    function permissionsListHas(d, moduleKey) {
      let perms = d.get('permissions', null);
      return perms is list && perms.hasAny([moduleKey]);
    }
    function hasTenantModulePermission(tenantId, moduleKey) {
      return tokenHasModulePermission(moduleKey)
        || (exists(tenantUserDocPath(tenantId)) && permissionsListHas(get(tenantUserDocPath(tenantId)).data, moduleKey))
        || (exists(authUserDocPath()) && permissionsListHas(get(authUserDocPath()).data, moduleKey));
    }
    function hasTenantMuralEventosPermission(tenantId) {
      return hasTenantModulePermission(tenantId, 'eventos')
        || hasTenantModulePermission(tenantId, 'eventos_avisos_edicao')
        || hasTenantModulePermission(tenantId, 'mural_avisos_edicao');
    }
    function muralPermissionKeysMatch(perms) {
      return perms is list && perms.hasAny(['eventos', 'eventos_avisos_edicao', 'mural_avisos_edicao']);
    }
    function memberMembroRoleString(d) {
      let r = d.get('role', '');
      return r.size() > 0 ? r : (d.get('FUNCAO', '').size() > 0 ? d.get('FUNCAO', '') : d.get('funcao', ''));
    }
    function memberMembroDataAllowsMural(d) {
      return muralSingleRoleAllowsMural(memberMembroRoleString(d))
        || (d.get('roles', null) is list && muralRolesArrayMatches(d.get('roles', [])));
    }
    function hasTenantMembrosDirectoryEditPermission(tenantId) {
      return hasTenantModulePermission(tenantId, 'membros') || hasTenantModulePermission(tenantId, 'membros_edicao');
    }
    function canWriteTenant(tenantId) {
      return canAccessTenant(tenantId) && (canManageChurch() || emailMatchesTenant(tenantId));
    }
    function membroPortariaRoleVariants() {
      return ['membro', 'MEMBRO', 'Membro', 'visitante', 'VISITANTE', 'Visitante'];
    }
    function isMembroPortariaRole() {
      let r = role();
      return r.size() > 0 && membroPortariaRoleVariants().hasAny([r]);
    }
    function pastoralSecretariatRoleVariants() {
      return ['PASTOR', 'pastor', 'PASTORA', 'pastora', 'Pastor', 'Pastora',
        'pastor_presidente', 'PASTOR_PRESIDENTE', 'Pastor Presidente', 'pastora_presidente',
        'SECRETARIO', 'secretario', 'SecretÃƒÂ¡rio', 'SECRETÃƒÂRIO', 'Secretario',
        'PRESBITERO', 'presbitero', 'PRESBITERA', 'presbitera', 'Presbitero', 'Presbitera'];
    }
    function isPastoralOrSecretariatRole() {
      let r = role();
      return r.size() > 0 && pastoralSecretariatRoleVariants().hasAny([r]);
    }
    function canWriteCertificadosPainel(tenantId) {
      return canAccessTenant(tenantId) && (
        canWriteTenant(tenantId) || isPastoralOrSecretariatRole() || isTreasurer()
        || hasTenantModulePermission(tenantId, 'certificados'));
    }
    function isEventosMuralEditorRole() {
      let r = role();
      return r.size() > 0 && (deptLeaderRoleVariants().hasAny([r]) || treasurerRoleVariants().hasAny([r]));
    }
    function isPastoralOrSecretariatMuralRole() {
      let r = role();
      return r.size() > 0 && (
        pastorOnlyRoleVariants().hasAny([r])
        || ['SECRETARIO', 'secretario', 'SecretÃƒÂ¡rio', 'SECRETÃƒÂRIO', 'Secretario', 'secretÃƒÂ¡ria', 'Secretaria'].hasAny([r])
      );
    }
    function staffRolesArrayMatches(roles) {
      return roles is list && roles.hasAny([
        'GESTOR', 'gestor', 'Gestor', 'ADMIN', 'ADM', 'admin', 'adm', 'Adm', 'Admin',
        'administrador', 'administradora', 'Administrador', 'Administradora',
        'PASTOR', 'pastor', 'PASTORA', 'pastora', 'Pastor', 'Pastora',
        'pastor_presidente', 'PASTOR_PRESIDENTE', 'Pastor Presidente', 'pastora_presidente',
        'pastor_auxiliar', 'PASTOR_AUXILIAR', 'Pastor Auxiliar', 'ministerial', 'pastor_auxiliar_ministerial',
        'SECRETARIO', 'secretario', 'SecretÃƒÂ¡rio', 'SECRETÃƒÂRIO', 'Secretario', 'secretÃƒÂ¡ria', 'Secretaria',
        'tesoureiro', 'TESOUREIRO', 'Tesoureiro', 'tesouraria', 'TESOURARIA', 'Tesouraria'
      ]);
    }
    function staffSingleRoleMatches(r) {
      return r.size() > 0 && staffRolesArrayMatches([r]);
    }
    function staffRoleFromRolesArrays(tenantId) {
      let rootRoles = exists(authUserDocPath()) && get(authUserDocPath()).data.roles is list
        ? get(authUserDocPath()).data.roles : [];
      let tenantRoles = exists(tenantUserDocPath(tenantId)) && get(tenantUserDocPath(tenantId)).data.roles is list
        ? get(tenantUserDocPath(tenantId)).data.roles : [];
      return staffRolesArrayMatches(rootRoles) || staffRolesArrayMatches(tenantRoles);
    }
    function staffMembroDataAllows(d) {
      return staffSingleRoleMatches(memberMembroRoleString(d))
        || (d.get('roles', null) is list && staffRolesArrayMatches(d.get('roles', [])));
    }
    function staffRoleFromMemberDoc(tenantId) {
      let byUid = membroDocPath(tenantId, request.auth.uid);
      return exists(byUid) && staffMembroDataAllows(get(byUid).data);
    }
    function staffRoleFromTenantUserDoc(tenantId) {
      let p = tenantUserDocPath(tenantId);
      return exists(p) && staffMembroDataAllows(get(p).data);
    }
    function staffRoleFromLinkedMemberDoc(tenantId) {
      return exists(authUserDocPath()) && (
        memberDocIdLinksAuthToMembroStaff(tenantId, get(authUserDocPath()).data)
        || cpf11MembroDocLinksAuthStaff(tenantId, get(authUserDocPath()).data)
      );
    }
    function isPlainMembroRole() {
      let r = role();
      return r.size() > 0 && membroPortariaRoleVariants().hasAny([r]);
    }
    function hasStaffDelegatedModuleWrite(tenantId) {
      return canAccessTenant(tenantId) && !isPlainMembroRole() && (
        hasTenantModulePermission(tenantId, 'eventos')
        || hasTenantModulePermission(tenantId, 'eventos_avisos_edicao')
        || hasTenantModulePermission(tenantId, 'mural_avisos_edicao')
        || hasTenantModulePermission(tenantId, 'patrimonio')
        || hasTenantModulePermission(tenantId, 'financeiro')
        || hasTenantModulePermission(tenantId, 'fornecedores'));
    }
    function isChurchStaffWriter(tenantId) {
      return isAdminPanel()
        || canWriteTenant(tenantId)
        || emailMatchesTenant(tenantId)
        || (canAccessTenant(tenantId) && isTreasurer())
        || (canAccessTenant(tenantId) && isPastoralOrSecretariatMuralRole())
        || (canAccessTenant(tenantId) && isEventosMuralEditorRole())
        || (emailMatchesTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatMuralRole() || isTreasurer() || isEventosMuralEditorRole()))
        || staffRoleFromMemberDoc(tenantId)
        || staffRoleFromLinkedMemberDoc(tenantId)
        || staffRoleFromTenantUserDoc(tenantId)
        || (canAccessTenant(tenantId) && staffRoleFromRolesArrays(tenantId))
        || hasStaffDelegatedModuleWrite(tenantId);
    }
    function tenantUserRoleAllowsMural(tenantId) {
      let p = tenantUserDocPath(tenantId);
      let r = exists(p) ? get(p).data.get('role', '') : '';
      return staffSingleRoleMatches(r);
    }
    function canWriteMuralFeed(tenantId) { return isChurchStaffWriter(tenantId); }
    function canWriteMuralFeedAllMembers(tenantId) {
      return isMaster() || canAccessTenant(tenantId) || memberLinkedToTenant(tenantId);
    }
    function canAccessCartasTenant(tenantId) {
      return isMaster() || canAccessTenant(tenantId) || memberLinkedToTenant(tenantId) || emailMatchesTenant(tenantId);
    }
    function canReadFinanceTenant(tenantId) {
      return isMaster() || canAccessTenant(tenantId) || memberLinkedToTenant(tenantId) || emailMatchesTenant(tenantId);
    }
    function staffTenantBindingFast(tenantId) {
      return tokenTenantMatches(tenantId) || userDocMatchesTenant(tenantId) || bpcClusterMatches(tenantId)
        || emailMatchesTenant(tenantId) || exists(tenantUserDocPath(tenantId));
    }
    function canReadMembrosDirectoryTenant(tenantId) {
      return isMaster() || isChurchStaffWriter(tenantId) || canAccessTenant(tenantId)
        || memberLinkedToTenant(tenantId) || emailMatchesTenant(tenantId)
        || (isSignedIn() && staffSingleRoleMatches(role()) && staffTenantBindingFast(tenantId))
        || staffRoleFromRolesArrays(tenantId) || staffRoleFromTenantUserDoc(tenantId)
        || staffRoleFromMemberDoc(tenantId) || staffRoleFromLinkedMemberDoc(tenantId);
    }
    function canAccessPatrimonioTenant(tenantId) {
      return isMaster() || isChurchStaffWriter(tenantId) || emailMatchesTenant(tenantId)
        || (canAccessTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatRole() || isPastoralOrSecretariatMuralRole() || isTreasurer() || hasTenantModulePermission(tenantId, 'patrimonio')))
        || (isSignedIn() && staffSingleRoleMatches(role()) && staffTenantBindingFast(tenantId))
        || staffRoleFromRolesArrays(tenantId) || staffRoleFromTenantUserDoc(tenantId)
        || staffRoleFromMemberDoc(tenantId) || staffRoleFromLinkedMemberDoc(tenantId);
    }
    function canAccessFornecedoresTenant(tenantId) {
      return isMaster() || isChurchStaffWriter(tenantId) || emailMatchesTenant(tenantId)
        || (canAccessTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatRole() || isPastoralOrSecretariatMuralRole() || isTreasurer() || hasTenantModulePermission(tenantId, 'fornecedores')))
        || (isSignedIn() && staffSingleRoleMatches(role()) && staffTenantBindingFast(tenantId))
        || staffRoleFromRolesArrays(tenantId) || staffRoleFromTenantUserDoc(tenantId)
        || staffRoleFromMemberDoc(tenantId) || staffRoleFromLinkedMemberDoc(tenantId);
    }
    function canAccessAprovacoesTenant(tenantId) {
      return isMaster() || isChurchStaffWriter(tenantId) || emailMatchesTenant(tenantId)
        || (canAccessTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatRole() || isPastoralOrSecretariatMuralRole() || isTreasurer() || hasTenantModulePermission(tenantId, 'membros') || hasTenantModulePermission(tenantId, 'membros_edicao')))
        || (isSignedIn() && staffSingleRoleMatches(role()) && staffTenantBindingFast(tenantId))
        || staffRoleFromRolesArrays(tenantId) || staffRoleFromTenantUserDoc(tenantId)
        || staffRoleFromMemberDoc(tenantId) || staffRoleFromLinkedMemberDoc(tenantId);
    }
    function deptLeaderFromMembroData(d) {
      return (d.get('FUNCOES', null) is list && deptLeaderRolesArrayMatches(d.get('FUNCOES', [])))
        || (d.get('roles', null) is list && deptLeaderRolesArrayMatches(d.get('roles', [])))
        || (memberMembroRoleString(d).size() > 0 && deptLeaderRolesArrayMatches([memberMembroRoleString(d)]));
    }
    function deptLeaderFromMemberDoc(tenantId) {
      let byUid = membroDocPath(tenantId, request.auth.uid);
      return exists(byUid) && deptLeaderFromMembroData(get(byUid).data);
    }
    function canAccessPedidosOracaoTenant(tenantId) {
      return isMaster() || isChurchStaffWriter(tenantId) || emailMatchesTenant(tenantId)
        || deptLeaderFromRolesArrays(tenantId) || deptLeaderFromMemberDoc(tenantId)
        || (isSignedIn() && isDepartmentLeaderRole() && (staffTenantBindingFast(tenantId) || canAccessTenant(tenantId)))
        || (canAccessTenant(tenantId) && (canManageChurch() || isPastoralOrSecretariatRole() || isPastoralOrSecretariatMuralRole() || isTreasurer()))
        || (isSignedIn() && staffSingleRoleMatches(role()) && staffTenantBindingFast(tenantId))
        || staffRoleFromRolesArrays(tenantId) || staffRoleFromTenantUserDoc(tenantId)
        || staffRoleFromMemberDoc(tenantId) || staffRoleFromLinkedMemberDoc(tenantId);
    }
    function pedidoOracaoCreatingAsAuthor() {
      return isSignedIn() && request.resource.data.get('autorUid', '') == request.auth.uid;
    }
    function pedidoOracaoAuthorOwnsResource() {
      return isSignedIn() && resource.data.get('autorUid', '') == request.auth.uid;
    }
    function chatTenantMemberFast(tenantId) {
      return isSignedIn() && (
        isMaster() || sameChurch(tenantId) || tokenTenantMatches(tenantId)
        || emailMatchesTenant(tenantId)
        || exists(tenantUserDocPath(tenantId))
        || exists(membroDocPath(tenantId, request.auth.uid))
        || memberLinkedToTenant(tenantId)
      );
    }
    function muralPostPublishFinalizeAllowed(tenantId) {
      return canWriteMuralFeedAllMembers(tenantId)
        && resource.data.get('publishState', '') == 'uploading'
        && request.resource.data.get('publishState', '') in ['published', 'failed']
        && resource.data.get('createdByUid', request.auth.uid) == request.auth.uid;
    }
    function canWriteTenantIfSignedIn(tenantId) { return isSignedIn(); }
    function canReadTenantIfSignedIn(tenantId) { return isSignedIn(); }

    // Site pÃƒÂºblico: post visÃƒÂ­vel se `publicSite` ausente ou true (legado: != false).
    function noticiaPublicReadable(tenantId, noticiaId) {
      let p = /databases/$(database)/documents/igrejas/$(tenantId)/noticias/$(noticiaId);
      return exists(p) && (!get(p).data.keys().hasAll(['publicSite']) || get(p).data.publicSite != false);
    }
    function avisoPostPublicReadable(tenantId, avisoId) {
      let p = /databases/$(database)/documents/igrejas/$(tenantId)/avisos/$(avisoId);
      return exists(p) && (!get(p).data.keys().hasAll(['publicSite']) || get(p).data.publicSite != false);
    }
    /// Leitura anÃƒÂ´nima alinhada ÃƒÂ  query `.where('publicSite', '==', true)` (list + get).
    function noticiaDocPublicSiteReadable() {
      return resource.data.publicSite == true
        || !('publicSite' in resource.data);
    }
    function avisoDocPublicSiteReadable() {
      return resource.data.publicSite == true
        || !('publicSite' in resource.data);
    }

    // Indisponibilidade para escalas: sÃƒÂ³ estes campos em `membros/{id}` (evita permission-denied quando authUid ainda nÃƒÂ£o foi gravado).
    function memberEmailMatchesAuth() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          ('EMAIL' in resource.data && resource.data.EMAIL == request.auth.token.email)
          || ('email' in resource.data && resource.data.email == request.auth.token.email)
        );
    }
    function escalaIndisponibilidadeUpdateOnly() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['escalaIndisponivelYmds', 'escalaIndisponivelUpdatedAt']);
    }

    // Membros da igreja podem atualizar sÃƒÂ³ campos sociais no post (curtida/RSVP/contagem)
    function noticiaSocialFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['likes', 'likesCount', 'rsvp', 'rsvpCount', 'commentsCount', 'likedBy']);
    }

    // PadrÃ£o: tudo vinculado Ã  igreja e ao gestor â€” patrimÃ´nio, fotos, vÃ­deos, notÃ­cias, escalas, membros, financeiro, etc.
    // igrejas/{id}/membros, noticias, eventos, patrimonio, finance, escalas, departamentos, cargos, visitantes, config, users...

    // Ãndice global slug â†’ churchId â€” leitura pÃºblica instantÃ¢nea (site + cadastro membro).
    match /public_church_slugs/{slugKey} {
      allow read: if true;
      allow write: if false;
    }

    match /igrejas/{id} {
      // Leitura pÃƒÂºblica para busca de igreja (CPF/e-mail) e perfil da igreja
      allow read: if true;
      // Escrita da igreja (cadastro, logo meta): staff â€” gestor, pastor, admin, secretÃ¡rio, tesoureiro.
      allow write: if isAdminPanel() || isChurchStaffWriter(id);

      match /membros/{memberId} {
        // AprovaÃ§Ãµes rÃ¡pidas + Membros + cartÃ£o membro â€” staff e vÃ­nculo igreja.
        allow read: if canReadMembrosDirectoryTenant(id) || canAccessAprovacoesTenant(id);

        // Cadastro pelo painel: staff da igreja (pastor/admin/secretÃƒÂ¡rio/tesoureiro/gestor) + isolamento tenant.
        // Cadastro pÃƒÂºblico (sem login) Ã¢â‚¬â€ status pendente atÃƒÂ© gestor aprovar.
        allow create: if (request.auth != null
          && canAccessTenant(id)
          && (isMaster() || canStaffEditAnyMemberRecord(id)))
          || (request.auth == null
          && request.resource.data.PUBLIC_SIGNUP == true
          && request.resource.data.MEMBER_ID == memberId
          && (request.resource.data.CPF is string)
          && (request.resource.data.STATUS == 'pendente' || request.resource.data.STATUS == 'ativo')
          && request.resource.data.NOME_COMPLETO is string
          && request.resource.data.DATA_NASCIMENTO is timestamp
          && request.resource.data.FOTO_URL_OU_ID is string
          && request.resource.data.EMAIL is string
          && request.resource.data.TELEFONES is string
          && request.resource.data.SEXO is string
          && request.resource.data.FAIXA_ETARIA is string
          && request.resource.data.IDADE is int
          && request.resource.data.ENDERECO is string
          && request.resource.data.CEP is string
          && request.resource.data.CIDADE is string
          && request.resource.data.BAIRRO is string
          && request.resource.data.ESTADO is string
          && request.resource.data.ESTADO_CIVIL is string
          && request.resource.data.ESCOLARIDADE is string
          && request.resource.data.NOME_CONJUGE is string
          && request.resource.data.FILIACAO is string
          && request.resource.data.DEPARTAMENTOS is list);

        // GravaÃƒÂ§ÃƒÂ£o: equipe (gestor, pastoral, secretÃƒÂ¡rio, tesoureiro) ou o prÃƒÂ³prio membro (ficha/CPF/authUid).
        // Foto de perfil: membro altera a sua; equipe altera qualquer uma no mÃƒÂ³dulo Membros (Storage + estes campos).
        allow update: if (request.auth == null
              && resource.data.PUBLIC_SIGNUP == true
              && resource.data.STATUS == 'pendente'
              && request.resource.data.STATUS == 'pendente')
          || (request.auth != null && (
              isMaster()
              || canStaffEditAnyMemberRecord(id)
              || canApprovePendingMemberRecord(id)
              || canAccessAprovacoesTenant(id)
              || (canAccessTenant(id) && isDepartmentLeaderRole())
              || (canAccessTenant(id) && deptLeaderFromRolesArrays(id))
              || (canAccessTenant(id) && hasTenantMembrosDirectoryEditPermission(id))
              || requesterOwnsMemberDoc(id, memberId)
              || (canAccessTenant(id) && escalaIndisponibilidadeUpdateOnly() && memberEmailMatchesAuth())
            ));
        allow delete: if request.auth != null
          && (isMaster() || canStaffEditAnyMemberRecord(id)
              || canApprovePendingMemberRecord(id)
              || canAccessAprovacoesTenant(id)
              || (canAccessTenant(id) && hasTenantMembrosDirectoryEditPermission(id)));
      }

      // Legado: leitura sÃƒÂ³ na prÃƒÂ³pria igreja (backup se Functions ainda nÃƒÂ£o rodaram).
      // Delete alinhado a `membros` Ã¢â‚¬â€ o app remove o par ao excluir membro; `write: false` bloqueava o batch inteiro.
      match /members/{memberId} {
        allow read: if canReadMembrosDirectoryTenant(id);
        allow create, update: if false;
        allow delete: if request.auth != null
          && (isMaster() || canWriteTenant(id) || (canAccessTenant(id) && isPastoralOrSecretariatRole())
              || (canAccessTenant(id) && hasTenantMembrosDirectoryEditPermission(id)));
      }

      match /config/{docId} {
        // `payment_receiving`: sÃ³ links pÃºblicos â€” leitura ampla para doaÃ§Ã£o web/iOS.
        // `finance_settings`: leitura estÃ¡vel para quem acede ao mÃ³dulo financeiro.
        allow read: if docId == 'payment_receiving'
          || isMaster()
          || (docId == 'finance_settings' && canReadFinanceTenant(id))
          || (docId == 'cartas' && canAccessCartasTenant(id))
          || (docId == 'carteira_signatories' && canReadMembrosDirectoryTenant(id))
          || (docId == 'patrimonio' && canAccessPatrimonioTenant(id))
          || (canAccessTenant(id) && (
            docId != 'mercado_pago'
            || canManageChurch()
            || hasTenantModulePermission(id, 'configuracoes_banco')
          ));
        allow write: if isAdminPanel() || canWriteTenant(id)
          || (docId == 'finance_settings' && isChurchStaffWriter(id))
          || (docId == 'cartas' && canAccessCartasTenant(id))
          || (docId == 'carteira_signatories' && canReadMembrosDirectoryTenant(id))
          || (docId == 'patrimonio' && canAccessPatrimonioTenant(id));
      }
      // Credenciais MP por igreja (Access Token) Ã¢â‚¬â€ sÃƒÂ³ servidor
      match /private/{docId} {
        allow read, write: if false;
      }
      // Resumo do painel (totais por mÃƒÂªs) Ã¢â‚¬â€ escrita sÃƒÂ³ Firebase Admin (Cloud Function); leitura gestÃƒÂ£o + site pÃƒÂºblico.
      match /_panel_cache/{docId} {
        allow read: if docId == 'public_site'
          || isMaster()
          || (docId == 'members_directory' && canReadMembrosDirectoryTenant(id))
          || (docId != 'members_directory' && (canAccessTenant(id) || memberLinkedToTenant(id)));
        allow write: if false;
      }
      // Registo de mÃ³dulos provisionados no welcome kit (finance, visitantes, â€¦) â€” escrita sÃ³ Admin SDK.
      match /_tenant_modules/{moduleId} {
        allow read: if isMaster() || canAccessTenant(id) || memberLinkedToTenant(id);
        allow write: if false;
      }
      // Cache agregado do dashboard â€” escrita sÃ³ Cloud Functions; 1 leitura na abertura.
      match /_dashboard_cache/{docId} {
        allow read: if isMaster() || canAccessTenant(id) || memberLinkedToTenant(id);
        allow write: if false;
      }
      // Contadores leves da Home (`members`, `avisos`, `eventos`) Ã¢â‚¬â€ leitura rÃƒÂ¡pida do painel.
      match /dashboard/{docId} {
        allow read: if isMaster() || canAccessTenant(id) || memberLinkedToTenant(id);
        allow write: if isMaster() || canWriteTenant(id);
      }
      match /_debug_platform_audit/{platformId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isMaster() || canWriteTenant(id);
        allow delete: if isMaster();
      }
      // Cache de performance Ã¢â‚¬â€ `public_feed` legÃƒÂ­vel no site pÃƒÂºblico (visitante / anÃƒÂ³nimo).
      match /_performance_cache/{docId} {
        allow read: if docId == 'public_feed'
          || isMaster()
          || canAccessTenant(id)
          || memberLinkedToTenant(id);
        allow write: if false;
      }
      match /finance_mp_notifications/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if false;
      }
      // HistÃƒÂ³rico leve de dÃƒÂ­zimos/ofertas (MP) Ã¢â‚¬â€ retenÃƒÂ§ÃƒÂ£o ~5 meses; escrita sÃƒÂ³ servidor (webhook / prune).
      match /contribuicoes_dizimo_historico/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if false;
      }
      // HistÃƒÂ³rico legado (reimpressÃƒÂ£o) Ã¢â‚¬â€ novos protocolos vÃƒÂ£o sÃƒÂ³ em certificados_emitidos.
      match /certificados_historico/{certId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update, delete: if isAdminPanel() || canWriteTenant(id);
      }
      // Cartas (apresentaÃƒÂ§ÃƒÂ£o / transferÃƒÂªncia) Ã¢â‚¬â€ histÃƒÂ³rico de emissÃƒÂµes no painel da igreja.
      match /cartas_historico/{hid} {
        allow read: if canAccessCartasTenant(id);
        allow create, update, delete: if canAccessCartasTenant(id);
      }
      match /cartas_modelos/{modeloId} {
        allow read: if canAccessCartasTenant(id);
        allow create, update, delete: if canAccessCartasTenant(id);
      }
      // Certificados emitidos (dados completos + QR) Ã¢â‚¬â€ por igreja.
      match /certificados_emitidos/{certId} {
        allow get: if true;
        allow list: if isMaster() || canAccessTenant(id);
        allow create: if isSignedIn()
          && request.resource.data.certificadoId == certId
          && request.resource.data.tenantId == id
          && request.resource.data.memberId is string
          && request.resource.data.nomeMembro is string
          && request.resource.data.emitidoPorUid is string
          && canWriteCertificadosPainel(id);
        allow update, delete: if isSignedIn()
          && resource.data.tenantId == id
          && canWriteCertificadosPainel(id);
      }
      // Frota Jim Sabores Ã¢â‚¬â€ dados por igreja; escrita autenticada (alinhado a fleet_* legado).
      match /abastecimentos/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isChurchStaffWriter(id);
        allow delete: if isMaster() || canWriteTenant(id);
      }
      match /combustiveis/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isChurchStaffWriter(id);
        allow delete: if isMaster() || canWriteTenant(id);
      }
      match /veiculos/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isChurchStaffWriter(id);
        allow delete: if isMaster() || canWriteTenant(id);
      }
      match /patrimonio/{docId} {
        allow read: if canAccessPatrimonioTenant(id);
        allow create, update, delete: if canAccessPatrimonioTenant(id);
        // SubcoleÃƒÂ§ÃƒÂµes do bem (manutenÃƒÂ§ÃƒÂµes, transferÃƒÂªncias) Ã¢â‚¬â€ mesmas permissÃƒÂµes do documento pai.
        match /manutencoes/{mid} {
          allow read: if canAccessPatrimonioTenant(id);
          allow create, update, delete: if canAccessPatrimonioTenant(id);
        }
        match /transferencias/{tid} {
          allow read: if canAccessPatrimonioTenant(id);
          allow create, update, delete: if canAccessPatrimonioTenant(id);
        }
      }
      // SessÃƒÂµes de inventÃƒÂ¡rio finalizadas (aba InventÃƒÂ¡rio Ã¢â‚¬â€ histÃƒÂ³rico auditÃƒÂ¡vel).
      match /patrimonio_inventario_historico/{hid} {
        allow read: if canAccessPatrimonioTenant(id);
        allow create, update, delete: if canAccessPatrimonioTenant(id);
      }
      // LanÃƒÂ§amentos: sem lista fechada de chaves no cliente Ã¢â‚¬â€ importaÃƒÂ§ÃƒÂ£o inteligente pode gravar
      // `smartPasteBatchId`, `source`, `parsedSnippet`, etc. (alinhado Controle Total; ver regras de merge no app).
      match /finance/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if isChurchStaffWriter(id);
      }
      // Auditoria: exclusÃƒÂµes e aÃƒÂ§ÃƒÂµes (somente append; sem ediÃƒÂ§ÃƒÂ£o pelo cliente).
      match /finance_logs/{logId} {
        allow read: if canReadFinanceTenant(id);
        allow create: if isChurchStaffWriter(id);
        allow update, delete: if false;
      }
      match /fornecedores/{docId} {
        allow read: if canAccessFornecedoresTenant(id);
        allow create, update, delete: if canAccessFornecedoresTenant(id);
      }
      match /fornecedor_compromissos/{docId} {
        allow read: if canAccessFornecedoresTenant(id);
        allow create, update, delete: if canAccessFornecedoresTenant(id);
      }
      match /categorias_receitas/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id) || isChurchStaffWriter(id);
      }
      match /categorias_despesas/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id) || isChurchStaffWriter(id);
      }
      match /contas/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id) || isChurchStaffWriter(id);
      }
      match /despesas_fixas/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id) || isChurchStaffWriter(id);
      }
      match /receitas_recorrentes/{docId} {
        allow read: if canReadFinanceTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id) || isChurchStaffWriter(id);
      }
      match /usersIndex/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id);
      }
      match /users/{userId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id);
      }
      match /fleet_vehicles/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isChurchStaffWriter(id);
        allow delete: if false;
      }
      match /fleet_fuelings/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isChurchStaffWriter(id);
        allow delete: if false;
      }
      match /fleet_documents/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update: if isChurchStaffWriter(id);
        allow delete: if false;
      }
      match /departamentos/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if canWriteIgrejaDepartamentos(id);
        // DenormalizaÃƒÂ§ÃƒÂ£o: membros vinculados ao grupo (performance em listas).
        match /membros_vinculados/{memberDocId} {
          allow read: if isMaster() || canAccessTenant(id);
          allow write: if canWriteIgrejaDepartamentos(id);
        }
      }
      match /cargos/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id);
      }
      match /funcoesControle/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id);
      }
      // HorÃƒÂ¡rios/capas de cultos fixos no site pÃƒÂºblico (visitante sem login).
      // Escrita: mesmo critÃƒÂ©rio do mural (`canWriteMuralFeed`) Ã¢â‚¬â€ lideranÃƒÂ§a da igreja, nÃƒÂ£o membro comum.
      match /event_templates/{docId} {
        allow read: if isMaster() || canAccessTenant(id)
          || !resource.data.keys().hasAll(['active']) || resource.data.active == true;
        allow write: if canWriteMuralFeedAllMembers(id);
      }
      // Categorias do mural de eventos (cor, nome) Ã¢â‚¬â€ painel e app.
      match /event_categories/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if canWriteMuralFeedAllMembers(id);
      }
      match /eventos/{docId} {
        allow read: if isMaster() || canAccessTenant(id)
          || noticiaDocPublicSiteReadable();
        allow create, delete: if canWriteMuralFeedAllMembers(id);
        allow update: if muralPostPublishFinalizeAllowed(id)
          || canWriteMuralFeedAllMembers(id)
          || (sameChurch(id) && isSignedIn() && noticiaSocialFieldsOnly());
        match /comentarios/{commentId} {
          allow read: if isMaster() || canAccessTenant(id) || noticiaPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id)
            && request.resource.data.authorUid == request.auth.uid
            && (request.resource.data.text is string || request.resource.data.texto is string);
          allow delete: if isAdminPanel() || canWriteTenant(id)
            || (isSignedIn() && resource.data.authorUid == request.auth.uid);
          allow update: if false;
        }
        match /curtidas/{uid} {
          allow read: if isMaster() || canAccessTenant(id) || noticiaPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id) && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.memberName is string;
          allow delete: if isSignedIn() && sameChurch(id) && request.auth.uid == uid;
          allow update: if false;
        }
        match /confirmacoes/{uid} {
          allow read: if isMaster() || canAccessTenant(id) || noticiaPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id) && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.memberName is string;
          allow delete: if isSignedIn() && sameChurch(id) && request.auth.uid == uid;
          allow update: if false;
        }
      }
      // Fila de upload descontinuada Ã¢â‚¬â€ limpeza pelo autor; app nÃƒÂ£o cria novos docs.
      match /pending_uploads/{uploadId} {
        allow read: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && isSignedIn()
          && resource.data.ownerUid == request.auth.uid;
        allow delete: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && isSignedIn()
          && resource.data.ownerUid == request.auth.uid;
        allow create, update: if false;
      }

      // Mural de avisos (Firestore): separado de `noticias` (eventos).
      match /avisos/{docId} {
        allow read: if isMaster() || canAccessTenant(id)
          || avisoDocPublicSiteReadable();
        allow create, delete: if canWriteMuralFeedAllMembers(id);
        allow update: if muralPostPublishFinalizeAllowed(id)
          || canWriteMuralFeedAllMembers(id)
          || (sameChurch(id) && isSignedIn() && noticiaSocialFieldsOnly());
        match /comentarios/{commentId} {
          allow read: if isMaster() || canAccessTenant(id) || avisoPostPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id)
            && request.resource.data.authorUid == request.auth.uid
            && (request.resource.data.text is string || request.resource.data.texto is string);
          allow delete: if isAdminPanel() || canWriteTenant(id)
            || (isSignedIn() && resource.data.authorUid == request.auth.uid);
          allow update: if false;
        }
        match /curtidas/{uid} {
          allow read: if isMaster() || canAccessTenant(id) || avisoPostPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id) && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.memberName is string;
          allow delete: if isSignedIn() && sameChurch(id) && request.auth.uid == uid;
          allow update: if false;
        }
        match /confirmacoes/{uid} {
          allow read: if isMaster() || canAccessTenant(id) || avisoPostPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id) && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.memberName is string;
          allow delete: if isSignedIn() && sameChurch(id) && request.auth.uid == uid;
          allow update: if false;
        }
      }
      // Eventos (subcoleÃƒÂ§ÃƒÂ£o legada/alternativa ao feed) Ã¢â‚¬â€ alinhado ao mural de eventos.
      match /noticias/{docId} {
        allow read: if isMaster() || canAccessTenant(id)
          || noticiaDocPublicSiteReadable();
        allow create, delete: if canWriteMuralFeedAllMembers(id);
        allow update: if muralPostPublishFinalizeAllowed(id)
          || canWriteMuralFeedAllMembers(id)
          || (sameChurch(id) && isSignedIn() && noticiaSocialFieldsOnly());
        match /comentarios/{commentId} {
          allow read: if isMaster() || canAccessTenant(id) || noticiaPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id)
            && request.resource.data.authorUid == request.auth.uid
            && (request.resource.data.text is string || request.resource.data.texto is string);
          allow delete: if isAdminPanel() || canWriteTenant(id)
            || (isSignedIn() && resource.data.authorUid == request.auth.uid);
          allow update: if false;
        }
        match /curtidas/{uid} {
          allow read: if isMaster() || canAccessTenant(id) || noticiaPublicReadable(id, docId);
          allow create: if isSignedIn() && sameChurch(id) && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.memberName is string;
          allow delete: if isSignedIn() && sameChurch(id) && request.auth.uid == uid;
          allow update: if false;
        }
      }
      match /eventos/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if canWriteMuralFeedAllMembers(id);
      }
      match /cultos/{cultoId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id);
        match /presencas/{presencaId} {
          allow read: if isMaster() || canAccessTenant(id);
          allow write: if isAdminPanel() || canWriteTenant(id);
        }
      }
      match /visitantes/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if isAdminPanel() || canWriteTenant(id)
          || (canAccessTenant(id) && isMembroPortariaRole());
        match /followups/{followupId} {
          allow read: if isMaster() || canAccessTenant(id);
          allow write: if isAdminPanel() || canWriteTenant(id)
            || (canAccessTenant(id) && isMembroPortariaRole());
        }
      }
      // Mensagens pastorais (push) Ã¢â‚¬â€ leitura para membros da igreja; escrita sÃƒÂ³ Cloud Functions / callables.
      match /pastoral_mensagens/{msgId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update, delete: if false;
        match /leituras/{uid} {
          allow read: if isMaster() || canAccessTenant(id);
          allow create, update: if isSignedIn() && canAccessTenant(id) && request.auth.uid == uid
            && (
              (request.resource.data.keys().hasOnly(['readAt']))
              || (request.resource.data.keys().hasOnly(['readAt', 'reply'])
                  && request.resource.data.reply is string
                  && request.resource.data.reply.size() <= 2000)
            );
        }
      }
      // HistÃƒÂ³rico de envios do devocional automÃƒÂ¡tico Ã¢â‚¬â€ escrita sÃƒÂ³ Cloud Functions; leitura no painel.
      match /devocional_envios/{docId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create, update, delete: if false;
      }
      match /pedidosOracao/{docId} {
        allow read: if canAccessPedidosOracaoTenant(id)
          || canAccessTenant(id)
          || memberLinkedToTenant(id);
        allow create: if canAccessPedidosOracaoTenant(id)
          || (canAccessTenant(id) && pedidoOracaoCreatingAsAuthor())
          || (memberLinkedToTenant(id) && pedidoOracaoCreatingAsAuthor());
        allow update: if canAccessPedidosOracaoTenant(id)
          || pedidoOracaoAuthorOwnsResource()
          || (canAccessTenant(id) && memberLinkedToTenant(id));
        allow delete: if canAccessPedidosOracaoTenant(id)
          || pedidoOracaoAuthorOwnsResource();
      }

      /// CPF 11 dÃƒÂ­gitos em `users/{uid}` Ã¢â‚¬â€ bate com `leaderCpfs` no departamento (escalas + chat).
      function userElevenDigitCpfFromUserData(d) {
        let raw = d.cpf is string ? d.cpf : (d.CPF is string ? d.CPF : '');
        return raw.size() == 11 && raw.matches('^[0-9]{11}$') ? raw : '';
      }
      function userElevenDigitCpfOrEmpty() {
        let u = /databases/$(database)/documents/users/$(request.auth.uid);
        return exists(u) ? userElevenDigitCpfFromUserData(get(u).data) : '';
      }
      /// CPF do login: `users/{uid}` ou ficha `membros/{authUid}` (comum em lÃƒÂ­deres de departamento).
      function userElevenDigitCpfForTenant(tenantId) {
        let fromUsers = userElevenDigitCpfOrEmpty();
        let pM = /databases/$(database)/documents/igrejas/$(tenantId)/membros/$(request.auth.uid);
        let fromMembro = exists(pM)
          ? (
              get(pM).data.CPF is string
              && get(pM).data.CPF.size() == 11
              && get(pM).data.CPF.matches('^[0-9]{11}$')
                ? get(pM).data.CPF
                : (
                    get(pM).data.cpf is string
                    && get(pM).data.cpf.size() == 11
                    && get(pM).data.cpf.matches('^[0-9]{11}$')
                      ? get(pM).data.cpf
                      : ''
                  )
            )
          : '';
        return fromUsers.size() == 11 ? fromUsers : fromMembro;
      }
      function departmentLeaderListsMatch(tenantId, dd) {
        let cpf = userElevenDigitCpfForTenant(tenantId);
        return dd.leaderUid == request.auth.uid
          || dd.leader_uid == request.auth.uid
          || (dd.leaderUids is list && dd.leaderUids.hasAny([request.auth.uid]))
          || (dd.leader_uids is list && dd.leader_uids.hasAny([request.auth.uid]))
          || (cpf.size() == 11 && (
            (dd.leaderCpfs is list && dd.leaderCpfs.hasAny([cpf])) ||
            (dd.leader_cpfs is list && dd.leader_cpfs.hasAny([cpf])) ||
            (dd.liderCpfs is list && dd.liderCpfs.hasAny([cpf])) ||
            (dd.lider_cpfs is list && dd.lider_cpfs.hasAny([cpf]))
          ));
      }
      function departmentDocListsRequesterAsLeader(tenantId, deptId) {
        let dpath = /databases/$(database)/documents/igrejas/$(tenantId)/departamentos/$(deptId);
        return exists(dpath) && departmentLeaderListsMatch(tenantId, get(dpath).data);
      }
      function escalaDeptIdFromRequest() {
        return request.resource.data.keys().hasAll(['departmentId'])
          && request.resource.data.departmentId is string
          ? request.resource.data.departmentId
          : '';
      }
      function escalaDeptIdFromResource() {
        return resource.data.keys().hasAll(['departmentId'])
          && resource.data.departmentId is string
          ? resource.data.departmentId
          : '';
      }
      function departmentLeaderMayWriteEscalaCreate(tenantId) {
        let deptId = escalaDeptIdFromRequest();
        return deptId.size() > 0
          && canAccessTenant(tenantId)
          && departmentDocListsRequesterAsLeader(tenantId, deptId);
      }
      function departmentLeaderMayWriteEscalaExisting(tenantId) {
        let deptId = escalaDeptIdFromResource();
        return deptId.size() > 0
          && canAccessTenant(tenantId)
          && departmentDocListsRequesterAsLeader(tenantId, deptId);
      }

      match /escala_templates/{tplId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create: if (isAdminPanel() || canWriteTenant(id))
          || departmentLeaderMayWriteEscalaCreate(id);
        allow update, delete: if (isAdminPanel() || canWriteTenant(id))
          || departmentLeaderMayWriteEscalaExisting(id);
      }
      // Membro na escala pode atualizar sÃƒÂ³ confirmaÃƒÂ§ÃƒÂ£o / indisponibilidade (prÃƒÂ³prio CPF no users).
      function userScheduleCpfDigits() {
        let p = /databases/$(database)/documents/users/$(request.auth.uid);
        let fromDoc = exists(p)
          ? (get(p).data.cpf is string
              ? get(p).data.cpf
              : (get(p).data.CPF is string ? get(p).data.CPF : ''))
          : '';
        let fromClaim = request.auth.token.cpf is string ? request.auth.token.cpf : '';
        return fromDoc.size() == 11 && fromDoc.matches('^[0-9]{11}$')
          ? fromDoc
          : (fromClaim.size() == 11 && fromClaim.matches('^[0-9]{11}$') ? fromClaim : '');
      }
      /// CPF da escala pode estar sÃƒÂ³ com pontuaÃƒÂ§ÃƒÂ£o em memberCpfs; ficha em membros/{uid} ou users bate com 11 dÃƒÂ­gitos.
      // NÃƒÂ£o exigir cpf em users antes de checar membros/{authUid}: muitos perfis sÃƒÂ³ tÃƒÂªm CPF na ficha.
      function scheduleMemberOnEscalaList(tenantId, memberCpfsList, cpfDigits) {
        return memberCpfsList is list
          && (
            (cpfDigits.size() == 11 && cpfDigits in memberCpfsList)
            || scheduleMembroCpfFieldsInMemberCpfsList(tenantId, memberCpfsList)
          );
      }
      function scheduleMembroCpfFieldsInMemberCpfsListViaCpf(tenantId, memberCpfsList) {
        let cp = userScheduleCpfDigits();
        let pC = /databases/$(database)/documents/igrejas/$(tenantId)/membros/$(cp);
        return cp.size() == 11
          && cp.matches('^[0-9]{11}$')
          && exists(pC)
          && (
            (get(pC).data.authUid == request.auth.uid)
            || (get(pC).data.firebaseUid == request.auth.uid)
          )
          && cp in memberCpfsList;
      }
      function scheduleMembroCpfFieldsInMemberCpfsList(tenantId, memberCpfsList) {
        let pU = /databases/$(database)/documents/igrejas/$(tenantId)/membros/$(request.auth.uid);
        return exists(pU)
          ? (
              (get(pU).data.CPF is string && get(pU).data.CPF in memberCpfsList)
              || (get(pU).data.cpf is string && get(pU).data.cpf in memberCpfsList)
            )
          : scheduleMembroCpfFieldsInMemberCpfsListViaCpf(tenantId, memberCpfsList);
      }
      function scheduleMemberSelfConfirmOnly(tenantId) {
        let cpf = userScheduleCpfDigits();
        return isSignedIn()
          && canAccessTenant(tenantId)
          && !canWriteTenant(tenantId)
          && resource.data.memberCpfs is list
          && scheduleMemberOnEscalaList(tenantId, resource.data.memberCpfs, cpf)
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['confirmations', 'unavailabilityReasons']);
      }
      // Forma mÃƒÂ­nima: listas de membros com tamanho razoÃƒÂ¡vel. Conflito de horÃƒÂ¡rio / ausÃƒÂªncias
      // sÃƒÂ£o validados no app (e em Cloud Functions onde aplicÃƒÂ¡vel); regras nÃƒÂ£o fazem get em N escalas.
      function escalaMemberListsShapeOk() {
        let d = request.resource.data;
        return d.memberCpfs is list
          && d.memberNames is list
          && d.memberCpfs.size() <= 120
          && d.memberNames.size() <= 120;
      }
      match /escalas/{escId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow create: if escalaMemberListsShapeOk()
          && (
            isAdminPanel() || canWriteTenant(id)
            || departmentLeaderMayWriteEscalaCreate(id)
          );
        allow delete: if isAdminPanel() || canWriteTenant(id)
          || departmentLeaderMayWriteEscalaExisting(id);
        allow update: if scheduleMemberSelfConfirmOnly(id)
          || (
            escalaMemberListsShapeOk()
            && (
              isAdminPanel() || canWriteTenant(id)
              || departmentLeaderMayWriteEscalaExisting(id)
            )
          );
      }
      // Pedido de troca de escala (membro Ã¢â€ â€™ lÃƒÂ­der aprova).
      match /escala_trocas/{trocaId} {
        allow read: if isMaster() || canAccessTenant(id);
        // pendente = fluxo legado (lÃƒÂ­der aprova no app); pendente_alvo = convite ao substituto (aceite via Cloud Function).
        allow create: if isSignedIn()
          && canAccessTenant(id)
          && request.resource.data.keys().hasAll(['escalaId', 'departmentId', 'solicitanteCpf', 'alvoCpf', 'status', 'createdAt'])
          && request.resource.data.escalaId is string
          && request.resource.data.departmentId is string
          && request.resource.data.solicitanteCpf is string
          && request.resource.data.alvoCpf is string
          && (request.resource.data.status == 'pendente' || request.resource.data.status == 'pendente_alvo')
          && scheduleTrocaSolicitanteMatches(id, request.resource.data.solicitanteCpf)
          && request.resource.data.solicitanteCpf != request.resource.data.alvoCpf;
        allow update, delete: if isAdminPanel() || canWriteTenant(id)
          || (
            canAccessTenant(id)
            && resource.data.departmentId is string
            && departmentDocListsRequesterAsLeader(id, resource.data.departmentId)
          );
      }
      function scheduleTrocaSolicitanteMatches(tenantId, solCpf) {
        return solCpf is string
          && solCpf.size() == 11
          && solCpf.matches('^[0-9]{11}$')
          && (
            solCpf == userScheduleCpfDigits()
            || scheduleTrocaSolicitanteViaMembroDoc(tenantId, solCpf)
            || scheduleTrocaSolicitanteViaMembroDocIdCpf(tenantId, solCpf)
          );
      }
      /// Ficha em `membros/{authUid}` com CPF igual ao solicitante.
      function scheduleTrocaSolicitanteViaMembroDoc(tenantId, solCpf) {
        let pU = /databases/$(database)/documents/igrejas/$(tenantId)/membros/$(request.auth.uid);
        return exists(pU)
          && (
            (get(pU).data.CPF is string && get(pU).data.CPF == solCpf)
            || (get(pU).data.cpf is string && get(pU).data.cpf == solCpf)
          );
      }
      /// Ficha em `membros/{cpf11}` (ID = CPF) com vÃƒÂ­nculo ao login Ã¢â‚¬â€ caso mais comum nas igrejas.
      function scheduleTrocaSolicitanteViaMembroDocIdCpf(tenantId, solCpf) {
        let pC = /databases/$(database)/documents/igrejas/$(tenantId)/membros/$(solCpf);
        return exists(pC)
          && (
            get(pC).data.authUid == request.auth.uid
            || get(pC).data.firebaseUid == request.auth.uid
          );
      }
      // Agenda inteligente (calendÃƒÂ¡rio interno Ã¢â‚¬â€ startTime / endTime / category).
      // Escrita: permissÃƒÂ£o granular `eventos` + papÃƒÂ©is do mural (nÃƒÂ£o sÃƒÂ³ gestor Ã¢â‚¬â€ igual `noticias`).
      match /agenda/{eventId} {
        allow read: if isMaster() || canAccessTenant(id);
        allow write: if canWriteMuralFeedAllMembers(id);
      }

      // Chat membro-a-membro / grupos por departamento
      function chatUserDeptIds(tenantId) {
        let p = /databases/$(database)/documents/igrejas/$(tenantId)/users_profile_chat/$(request.auth.uid);
        return exists(p) && get(p).data.departmentIds is list
          ? get(p).data.departmentIds
          : [];
      }
      /// Gestor/pastor/secretÃ¡rio/tesoureiro/adm â€” leem **todos** os grupos de departamento (aba Grupos).
      function chatGroupChurchLeadership(tenantId) {
        return canAccessTenant(tenantId) && (
          canWriteTenant(tenantId)
          || isPastoralOrSecretariatRole()
          || isTreasurer()
          || isAdminPanel()
        );
      }
      /// DM pelo id `dm_{uidA}_{uidB}` Ã¢â‚¬â€ legado sem `participantUids` ainda pode listar/ler.
      function dmThreadAuthUserInThreadId(threadId) {
        return threadId.matches('^dm_[^_]+_[^_]+$')
          && (
            threadId.matches('^dm_' + request.auth.uid + '_')
            || threadId.matches('_' + request.auth.uid + '$')
          );
      }

      /// Leitura do doc do thread Ã¢â‚¬â€ usa `resource.data` + [threadId] (sem `get(thread)` em listagens).
      /// Fallback `dm_` / `dept_` no id quando `type` em falta (dados antigos / merge parcial).
      /// Importante: em queries `where participantUids arrayContains uid`, se **um** documento
      /// devolvido falhar `allow read`, o Firestore falha a **lista inteira** (permission-denied).
      /// Por isso: quem estÃƒÂ¡ em `participantUids` pode ler o thread (metadados), mesmo com `type`/id atÃƒÂ­picos.
      function canReadChatThreadData(tenantId, threadId, d) {
        let inParticipants = d.participantUids is list && request.auth.uid in d.participantUids;
        let asDm = d.type == 'dm' || threadId.matches('^dm_.+');
        let asDept = d.type == 'department' || threadId.matches('^dept_.+');
        return (asDm && (inParticipants || dmThreadAuthUserInThreadId(threadId)))
          || (asDept && (
            chatGroupChurchLeadership(tenantId)
            || inParticipants
            || (d.departmentId is string && chatUserDeptIds(tenantId).hasAny([d.departmentId]))
          ))
          || inParticipants
          || dmThreadAuthUserInThreadId(threadId);
      }

      /// Mensagens / typing / helpers Ã¢â‚¬â€ leem o doc pai via `get()`.
      function canReadChatThreadDoc(tenantId, threadId) {
        let path = /databases/$(database)/documents/igrejas/$(tenantId)/chats/$(threadId);
        return exists(path) && canReadChatThreadData(tenantId, threadId, get(path).data);
      }

      /// Envio de mensagem Ã¢â‚¬â€ um `get(thread)`; sem `canReadChatThreadData` (menos latÃƒÂªncia no create).
      function chatSenderMayPostToThread(tenantId, threadId) {
        let path = /databases/$(database)/documents/igrejas/$(tenantId)/chats/$(threadId);
        let t = exists(path) ? get(path).data : {};
        let isDept = t.type == 'department' || threadId.matches('^dept_.+');
        return exists(path) && (
          (t.participantUids is list && request.auth.uid in t.participantUids)
          || dmThreadAuthUserInThreadId(threadId)
          || (isDept && (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId)))
          || (memberLinkedToTenant(tenantId) && dmThreadAuthUserInThreadId(threadId))
          || canWriteTenant(tenantId)
          || (emailMatchesTenant(tenantId) && isSignedIn())
        );
      }

      /// ApÃƒÂ³s enviar mensagem o app faz merge sÃƒÂ³ nestes campos do thread.
      function chatThreadLastMessagePatchAllowed() {
        return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'lastMessageAt', 'lastMessagePreview', 'lastMessage', 'lastMessageType',
          'lastSenderUid', 'updatedAt', 'hasConversation'
        ]);
      }

      /// Pastores / pastoral auxiliar Ã¢â‚¬â€ moderar remoÃƒÂ§ÃƒÂ£o de mensagens (alinhado ao app).
      function chatPastoralModeratorRole() {
        let r = role();
        return r != null && (
          r == 'PASTOR' || r == 'pastor' || r == 'PASTORA' || r == 'pastora' || r == 'Pastor' || r == 'Pastora' ||
          r == 'pastor_presidente' || r == 'PASTOR_PRESIDENTE' || r == 'Pastor Presidente' ||
          r == 'pastor_auxiliar' || r == 'PASTOR_AUXILIAR' || r == 'Pastor Auxiliar' ||
          r == 'ministerial' || r == 'pastor_auxiliar_ministerial'
        );
      }

      /// LÃƒÂ­der do departamento do grupo (`leaderCpfs` / `leaderUids` no doc departamentos) Ã¢â‚¬â€ alinhado a [ChurchChatModeration].
      function chatDepartmentLeaderOfThread(tenantId, threadId, t) {
        let deptId = t.departmentId is string && t.departmentId.size() > 0 ? t.departmentId : '';
        return deptId.size() > 0
          && (canAccessTenant(tenantId) || memberLinkedToTenant(tenantId))
          && departmentDocListsRequesterAsLeader(tenantId, deptId);
      }

      /// Ã‚Â«Apagar para todosÃ‚Â» (DELETE): DM Ã¢â‚¬â€ qualquer participante pode apagar qualquer mensagem (estilo limpar conversa).
      /// Grupo Ã¢â‚¬â€ o autor apaga a prÃƒÂ³pria; pastor/gestor/ADM/secretÃƒÂ¡rio/tesoureiro ou lÃƒÂ­der do departamento apagam qualquer uma.
      function chatMessageDeleteForEveryoneAllowed(tenantId, threadId) {
        let path = /databases/$(database)/documents/igrejas/$(tenantId)/chats/$(threadId);
        let t = get(path).data;
        let participants = t.participantUids is list && request.auth.uid in t.participantUids;
        let isDm = t.type == 'dm' || threadId.matches('^dm_.+');
        let isDept = t.type == 'department' || threadId.matches('^dept_.+');
        return isSignedIn() && exists(path)
          && resource.data.keys().hasAll(['senderUid'])
          && resource.data.senderUid is string
          && (
            isAdminPanel()
            || canWriteTenant(tenantId)
            || chatPastoralModeratorRole()
            || isTreasurer()
            || isPastoralOrSecretariatRole()
            || (isDept && chatDepartmentLeaderOfThread(tenantId, threadId, t))
            || (isDm && participants)
            || (
              isDept
              && participants
              && resource.data.senderUid == request.auth.uid
            )
          );
      }

      /// Apagar o documento do thread (ex.: grupo de departamento): gestÃƒÂ£o/pastoral ou lÃƒÂ­der do departamento.
      function chatThreadDeleteAllowed(tenantId, threadId) {
        let path = /databases/$(database)/documents/igrejas/$(tenantId)/chats/$(threadId);
        let t = exists(path) ? get(path).data : {};
        let isDept = t.type == 'department' || threadId.matches('^dept_.+');
        return isAdminPanel()
          || canWriteTenant(tenantId)
          || chatPastoralModeratorRole()
          || isTreasurer()
          || isPastoralOrSecretariatRole()
          || (isDept && chatDepartmentLeaderOfThread(tenantId, threadId, t));
      }

      /// Ã‚Â«Apagar para mimÃ‚Â»: sÃƒÂ³ acrescenta o prÃƒÂ³prio uid em `hiddenForUids` (merge seguro).
      function chatMessageHideForMeOnly(tenantId, threadId) {
        return canAccessTenant(tenantId)
          && canReadChatThreadDoc(tenantId, threadId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['hiddenForUids'])
          && request.resource.data.hiddenForUids is list
          && request.auth.uid in request.resource.data.hiddenForUids
          && (
            !('hiddenForUids' in resource.data)
            || !(request.auth.uid in resource.data.hiddenForUids)
          );
      }

      /// ReaÃƒÂ§ÃƒÂµes: sÃƒÂ³ o mapa `reactionsByUid` pode mudar (merge transacional no cliente).
      function chatMessageReactionsByUidOnly(tenantId, threadId) {
        return canAccessTenant(tenantId)
          && canReadChatThreadDoc(tenantId, threadId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['reactionsByUid'])
          && request.resource.data.reactionsByUid is map
          && request.resource.data.reactionsByUid.size() <= 48;
      }

      /// MÃƒÂ­dia: stub Ã‚Â«uploadingÃ‚Â» Ã¢â€ â€™ `sent` apÃƒÂ³s Storage Ã¢â‚¬â€ sem segundo `get(thread)` (sÃƒÂ³ valida remetente).
      function chatMessageSendingFinalizeAllowed(tenantId, threadId) {
        return (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId) || canWriteTenant(tenantId))
          && resource.data.senderUid == request.auth.uid
          && resource.data.deliveryStatus == 'sending'
          && request.resource.data.deliveryStatus == 'sent'
          && (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['deliveryStatus'])
            || (
              resource.data.type == 'sticker'
              && request.resource.data.mediaUrl is string
              && request.resource.data.mediaUrl.size() > 8
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'deliveryStatus', 'mediaUrl', 'storagePath', 'stickerSource'
              ])
            )
          );
      }

      function chatMessageMediaDeliveryPatchAllowed(tenantId, threadId) {
        return (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId) || canWriteTenant(tenantId))
          && resource.data.senderUid == request.auth.uid
          && resource.data.deliveryStatus in ['uploading', 'queued']
          && request.resource.data.deliveryStatus == 'sent'
          && request.resource.data.storagePath is string
          && request.resource.data.storagePath.size() > 16
          && request.resource.data.storagePath.matches('^igrejas/.+/chat_media/.+')
          && request.resource.data.uploadCompleted == true
          && request.resource.data.storageVerified == true
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'mediaUrl', 'fileUrl', 'storagePath', 'fileName', 'deliveryStatus', 'status',
            'uploadProgress', 'thumbUrl', 'thumbnailUrl', 'thumbStoragePath', 'fileSize', 'size',
            'uploadCompleted', 'storageVerified', 'updatedAt', 'pendingMedia', 'erro', 'errorMessage'
          ]);
      }

      function chatMessageMediaUploadFailedAllowed(tenantId, threadId) {
        return (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId) || canWriteTenant(tenantId))
          && resource.data.senderUid == request.auth.uid
          && resource.data.deliveryStatus in ['uploading', 'queued']
          && request.resource.data.deliveryStatus == 'failed'
          && request.resource.data.uploadCompleted == false
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'deliveryStatus', 'status', 'uploadProgress', 'uploadCompleted', 'storageVerified',
            'pendingMedia', 'erro', 'errorMessage', 'updatedAt'
          ]);
      }

      function chatMessageUploadProgressOnly(tenantId, threadId) {
        return (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId) || canWriteTenant(tenantId))
          && resource.data.senderUid == request.auth.uid
          && resource.data.deliveryStatus in ['uploading', 'queued']
          && request.resource.data.deliveryStatus in ['uploading', 'queued']
          && request.resource.data.uploadProgress is number
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['uploadProgress', 'deliveryStatus']);
      }

      function chatMessageUploadQueuedOnly(tenantId, threadId) {
        return (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId) || canWriteTenant(tenantId))
          && resource.data.senderUid == request.auth.uid
          && resource.data.deliveryStatus in ['uploading', 'queued']
          && request.resource.data.deliveryStatus == 'queued'
          && request.resource.data.uploadProgress is number
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['deliveryStatus', 'uploadProgress']);
      }

      /// DestinatÃƒÂ¡rio marca mensagens do remetente como entregues (Ã¢Å“â€œÃ¢Å“â€œ).
      function chatMessageDeliveredByRecipient(tenantId, threadId) {
        return (chatTenantMemberFast(tenantId) || memberLinkedToTenant(tenantId))
          && canReadChatThreadDoc(tenantId, threadId)
          && resource.data.senderUid != request.auth.uid
          && resource.data.deliveryStatus == 'sent'
          && request.resource.data.deliveryStatus == 'delivered'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['deliveryStatus']);
      }

      match /users_profile_chat/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid
          && (canAccessTenant(id) || memberLinkedToTenant(id));
        allow create, update: if isSignedIn() && request.auth.uid == uid
          && (canAccessTenant(id) || memberLinkedToTenant(id));
        allow delete: if false;
      }

      match /chat_presence/{uid} {
        allow read: if canAccessTenant(id) || memberLinkedToTenant(id);
        allow create, update: if isSignedIn() && request.auth.uid == uid
          && (canAccessTenant(id) || memberLinkedToTenant(id));
        allow delete: if false;
      }

      // Cache de foto/nome para Chat Igreja (escrito pelo Admin SDK ao atualizar membros).
      match /chat_peer_profiles/{authUid} {
        allow read: if canAccessTenant(id);
        allow write: if false;
      }

      // Favoritos / silenciar conversa / bloquear contacto (chat) Ã¢â‚¬â€ sÃƒÂ³ o prÃƒÂ³prio doc.
      match /chat_member_prefs/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid
          && (canAccessTenant(id) || memberLinkedToTenant(id));
        allow create, update: if isSignedIn() && request.auth.uid == uid
          && (canAccessTenant(id) || memberLinkedToTenant(id));
        allow delete: if false;
      }

      // Uploads de mÃƒÂ­dia do chat em curso (retoma apÃƒÂ³s fechar o app).
      match /chat_uploads/{uploadId} {
        allow read: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && isSignedIn()
          && resource.data.ownerUid == request.auth.uid;
        allow create: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && isSignedIn()
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.threadId is string
          && request.resource.data.localId is string
          && request.resource.data.kind is string
          && request.resource.data.status is string
          && request.resource.data.progress is number
          && request.resource.data.keys().size() <= 18;
        allow update: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status', 'progress', 'messageId', 'storagePath', 'localPath',
            'updatedAt', 'lastError', 'fileName', 'mime'
          ]);
        allow delete: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && isSignedIn()
          && resource.data.ownerUid == request.auth.uid;
      }

      // Figurinhas do chat Ã¢â‚¬â€ biblioteca partilhada por igreja (importaÃƒÂ§ÃƒÂ£o de imagens).
      match /chat_stickers/{stickerId} {
        allow read: if canAccessTenant(id);
        allow create: if canAccessTenant(id) && isSignedIn()
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.keys().hasAll(['createdAt', 'createdByUid', 'mediaUrl', 'storagePath', 'source'])
          && request.resource.data.createdByUid is string
          && request.resource.data.mediaUrl is string
          && request.resource.data.storagePath is string
          && request.resource.data.source == 'upload'
          && request.resource.data.keys().size() <= 10
          && (!('label' in request.resource.data) || request.resource.data.label is string);
        allow update: if false;
        allow delete: if canAccessTenant(id) && isSignedIn()
          && resource.data.createdByUid == request.auth.uid;
      }

      match /chats/{threadId} {
        // Lista/query: `where participantUids arrayContains uid` Ã¢â‚¬â€ cada doc devolvido tem de passar `read`.
        // `memberLinkedToTenant`: nativo sem `igrejaId` no token (sÃƒÂ³ ficha em `membros/{cpf}`).
        allow read: if (canAccessTenant(id) || memberLinkedToTenant(id)) && (
            (resource.data.participantUids is list
              && request.auth.uid in resource.data.participantUids)
            || dmThreadAuthUserInThreadId(threadId)
            || canReadChatThreadData(id, threadId, resource.data)
          );
        allow create: if (canAccessTenant(id) || memberLinkedToTenant(id))
          && (
            (request.resource.data.type == 'dm'
              && request.resource.data.participantUids is list
              && request.auth.uid in request.resource.data.participantUids)
            || (request.resource.data.type == 'department'
              && request.resource.data.departmentId is string
              && (
                chatUserDeptIds(id).hasAny([request.resource.data.departmentId])
                || memberLinkedToTenant(id)
              ))
          );
        allow update: if (
          (resource.data.participantUids is list
            && request.auth.uid in resource.data.participantUids
            && chatThreadLastMessagePatchAllowed())
          || (chatTenantMemberFast(id) && chatThreadLastMessagePatchAllowed())
          || ((canAccessTenant(id) || memberLinkedToTenant(id))
            && canReadChatThreadData(id, threadId, resource.data))
          || dmThreadAuthUserInThreadId(threadId)
        );
        allow delete: if chatThreadDeleteAllowed(id, threadId);

        match /typing/{typingUid} {
          allow read: if (canAccessTenant(id) || memberLinkedToTenant(id))
            && canReadChatThreadDoc(id, threadId);
          allow create, update: if (canAccessTenant(id) || memberLinkedToTenant(id))
            && canReadChatThreadDoc(id, threadId)
            && request.auth.uid == typingUid
            && request.resource.data.keys().hasAll(['updatedAt'])
            && request.resource.data.updatedAt is timestamp
            && request.resource.data.keys().hasOnly(['updatedAt', 'label'])
            && (!('label' in request.resource.data) || request.resource.data.label is string);
          allow delete: if (canAccessTenant(id) || memberLinkedToTenant(id))
            && canReadChatThreadDoc(id, threadId)
            && request.auth.uid == typingUid;
        }

        match /messages/{msgId} {
          allow read: if (canAccessTenant(id) || memberLinkedToTenant(id))
            && canReadChatThreadDoc(id, threadId);
          allow create: if (chatTenantMemberFast(id) || memberLinkedToTenant(id) || canWriteTenant(id))
            && chatSenderMayPostToThread(id, threadId)
            && request.resource.data.senderUid == request.auth.uid
            && request.resource.data.keys().hasAll(['senderUid', 'type', 'createdAt', 'expiresAt'])
            && (!('senderDisplayName' in request.resource.data) || (
              request.resource.data.senderDisplayName is string
              && request.resource.data.senderDisplayName.size() > 0
              && request.resource.data.senderDisplayName.size() <= 100
            ))
            && !('reactionsByUid' in request.resource.data)
            && (!('mentionedUids' in request.resource.data) || (
              request.resource.data.mentionedUids is list
              && request.resource.data.mentionedUids.size() <= 24
            ))
            && (!('replyTo' in request.resource.data) || (
              request.resource.data.replyTo is map
              && request.resource.data.replyTo.keys().hasOnly(['messageId', 'senderUid', 'preview', 'type'])
              && request.resource.data.replyTo.messageId is string
              && request.resource.data.replyTo.senderUid is string
              && request.resource.data.replyTo.preview is string
              && request.resource.data.replyTo.type is string
              && request.resource.data.replyTo.messageId.size() > 0
              && request.resource.data.replyTo.preview.size() <= 240
            ));
          allow update: if chatMessageMediaDeliveryPatchAllowed(id, threadId)
            || chatMessageMediaUploadFailedAllowed(id, threadId)
            || chatMessageSendingFinalizeAllowed(id, threadId)
            || chatMessageUploadProgressOnly(id, threadId)
            || chatMessageUploadQueuedOnly(id, threadId)
            || chatMessageDeliveredByRecipient(id, threadId)
            || chatMessageHideForMeOnly(id, threadId)
            || chatMessageReactionsByUidOnly(id, threadId);
          allow delete: if (canAccessTenant(id) || memberLinkedToTenant(id))
            && canReadChatThreadDoc(id, threadId)
            && chatMessageDeleteForEveryoneAllowed(id, threadId);
        }
      }

      // Pontes Mercado Pago (webhook Ã¢â‚¬â€ sÃƒÂ³ Admin SDK / Functions).
      match /mp_payment_bridge/{bridgeId} {
        allow read, write: if false;
      }
      match /mp_preference_bridge/{bridgeId} {
        allow read, write: if false;
      }
      // ÃƒÂndice mÃƒÂ­nimo UUID Ã¢â€ â€™ validaÃƒÂ§ÃƒÂ£o pÃƒÂºblica do QR (dados em certificados_emitidos).
      match /certificados_protocol_index/{certId} {
        allow get: if true;
        allow list: if false;
        allow create: if isSignedIn() && canWriteCertificadosPainel(id);
        allow update, delete: if false;
      }
    }

    // Perfil do prÃƒÂ³prio usuÃƒÂ¡rio; listagem Membros: ver users do mesmo tenant (por doc do leitor ou token).
    function onlyDismissAnnouncementKeys() {
      let k = request.resource.data.keys();
      return k.hasOnly(['dismissedGlobalAnnouncementAt'])
        || k.hasOnly(['dismissedGlobalAnnouncementRev'])
        || k.hasOnly(['dismissedGlobalAnnouncementMsgHash'])
        || k.hasOnly(['dismissedGlobalAnnouncementAt', 'dismissedGlobalAnnouncementRev'])
        || k.hasOnly(['dismissedGlobalAnnouncementAt', 'dismissedGlobalAnnouncementMsgHash']);
    }

    match /users/{uid} {
      allow read, update: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid && onlyDismissAnnouncementKeys();
      allow read: if isMaster()
        || (canManageChurch() && (sameChurch(resource.data.igrejaId) || sameChurch(resource.data.tenantId)))
        || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == resource.data.tenantId
                || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.igrejaId == resource.data.igrejaId
                || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == resource.data.igrejaId
                || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.igrejaId == resource.data.tenantId))
        || (isSignedIn() && request.auth.token.tenantId != null && (resource.data.tenantId == request.auth.token.tenantId || resource.data.igrejaId == request.auth.token.tenantId))
        || (isSignedIn() && request.auth.token.igrejaId != null && (resource.data.tenantId == request.auth.token.igrejaId || resource.data.igrejaId == request.auth.token.igrejaId))
        || (isSignedIn());  // fallback: autenticado pode ler (evita lista de membros vazia)
      // ExclusÃƒÂ£o pelo painel: mesma ideia que igrejas/{id}/membros/{id} (gestor + pastoral + mÃƒÂ³dulo membros).
      // Admin painel YAHWEH + legado sem tenantId/igrejaId no doc `users/`.
      allow delete: if isMaster() || isAdminPanel()
        || (isSignedIn() && (
          (resource.data.tenantId is string && resource.data.tenantId != ''
            && (canWriteTenant(resource.data.tenantId)
              || (canAccessTenant(resource.data.tenantId) && isPastoralOrSecretariatRole())
              || (canAccessTenant(resource.data.tenantId) && hasTenantMembrosDirectoryEditPermission(resource.data.tenantId))))
          || (resource.data.igrejaId is string && resource.data.igrejaId != ''
            && (canWriteTenant(resource.data.igrejaId)
              || (canAccessTenant(resource.data.igrejaId) && isPastoralOrSecretariatRole())
              || (canAccessTenant(resource.data.igrejaId) && hasTenantMembrosDirectoryEditPermission(resource.data.igrejaId))))
        ));

      match /fcmTokens/{token} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    match /subscriptions/{id} {
      allow read: if (canManageChurch() && sameChurch(resource.data.igrejaId)) || isAdminPanel();
      allow write: if false; // server only
    }

    match /config/plans/items/{id} {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }

    // ÃƒÂndice mÃƒÂ­nimo CPF Ã¢â€ â€™ igreja (escrita sÃƒÂ³ Admin SDK / Functions)
    match /publicCpfIndex/{cpfKey} {
      allow read: if true;
      allow write: if false;
    }

    match /config/appVersion {
      allow read: if true;
      allow write: if isMaster();
    }
    match /config/appDownloads {
      allow read: if true;
      allow write: if isMaster();
    }

    // Links oficiais Instagram / YouTube / WhatsApp + nome de exibiÃƒÂ§ÃƒÂ£o (site divulgaÃƒÂ§ÃƒÂ£o + login)
    match /config/marketing_official {
      allow read: if true;
      allow write: if isMaster();
    }

    match /config/memberCard {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }
    // Acessos ao domÃƒÂ­nio Ã¢â‚¬â€ painel master (config/analytics ou analytics/domain/daily_hits)
    // Aviso global (melhorias / manutenÃƒÂ§ÃƒÂ£o) Ã¢â‚¬â€ leitura por qualquer usuÃƒÂ¡rio logado; escrita: master/adm (doc, roles array ou token)
    match /config/global_announcement {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }

    // Termos de Uso e PolÃ­tica de Privacidade â€” leitura pÃºblica (login/site); escrita: master
    match /config/legal_documents {
      allow read: if true;
      allow write: if isMaster();
    }

    // HistÃƒÂ³rico de avisos globais (somente operador de plataforma).
    match /global_announcement_audit/{id} {
      allow read, create, delete: if isMaster();
      allow update: if false;
    }

    // Resumo KPIs Painel Master Ã¢â‚¬â€ escrita sÃƒÂ³ Admin SDK (Cloud Functions).
    match /config/master_dashboard_summary {
      allow read: if isAdminPanel();
      allow write: if false;
    }
    match /config/master_churches_index {
      allow read: if isAdminPanel();
      allow write: if false;
    }
    match /config/featureFlags {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }
    match /config/_master_dashboard_lock {
      allow read, write: if false;
    }
    match /config/_master_churches_list_lock {
      allow read, write: if false;
    }

    match /config/analytics {
      allow read: if isSignedIn() && isMaster();
      allow write: if isMaster();
    }
    match /analytics/{docId} {
      allow read: if isSignedIn() && isMaster();
      allow write: if isMaster();
      match /daily_hits/{hitId} {
        allow read: if isSignedIn() && isMaster();
        allow write: if isMaster();
      }
    }

    // Recebimentos / licenÃƒÂ§as: mesmo critÃƒÂ©rio do painel (MASTER, ADM ou doc admins/{uid})
    match /sales/{id} {
      allow read: if isAdminPanel();
      allow create, update: if isAdminPanel();
      allow delete: if false;
    }

    // Pagamentos Mercado Pago (painel admin Ã¢â‚¬â€ Recebimentos de LicenÃƒÂ§as)
    match /mp_payments/{id} {
      allow read: if isAdminPanel();
      allow create, update: if isAdminPanel();
      allow delete: if false;
    }

    // Ponte MP igreja Ã¢â€ â€™ webhook (somente Cloud Functions / Admin SDK)
    match /church_mp_payments/{id} {
      allow read, write: if false;
    }

    match /licenses/{id} {
      allow read: if isAdminPanel();
      allow create, update: if isAdminPanel();
      allow delete: if false;
    }

    match /frota_customers/{id} {
      allow read: if isAdminPanel();
      allow create, update: if isAdminPanel();
      allow delete: if false;
    }

    match /drive_archives/{id} {
      allow read: if isAdminPanel();
      allow write: if false;
    }

    // Config Mercado Pago (painel admin): master/adm/admins doc
    match /config/mercado_pago {
      allow read, write: if isAdminPanel();
    }

    // CustomizaÃƒÂ§ÃƒÂ£o do sistema (tÃƒÂ­tulo, boas-vindas, tema) Ã¢â‚¬â€ escrita: master; leitura: logados (modal boas-vindas gestor)
    match /config/sistema {
      allow read: if isSignedIn();
      allow write: if isAdminPanel();
    }

    match /planos/{id} {
      allow read, write: if isAdminPanel();
    }

    match /pagamentos/{id} {
      allow read, write: if isAdminPanel();
    }

    match /alertas/{id} {
      allow read: if isAdminPanel();
      allow write: if isAdminPanel();
    }

    // Chamados de suporte (painel master)
    match /suporte/{id} {
      allow read, update: if isAdminPanel();
      allow create: if isSignedIn();
      allow delete: if isAdminPanel();
    }

    // SugestÃƒÂµes/CrÃƒÂ­ticas Ã¢â‚¬â€ operador global ou autor do documento.
    match /suggestions/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow update: if isMaster();
      allow delete: if isMaster();
    }

    // ADMIN (painel master atual) Ã¢â‚¬â€ leitura para todo painel master (inclui quem entra sÃƒÂ³ por admins/{uid})
    match /admins/{uid} {
      allow read: if isAdminPanel();
      allow write: if false;
    }

    // Auditoria: leitura apenas painel master; escrita somente backend (Admin SDK / Functions).
    match /auditoria/{id} {
      allow read: if isAdminPanel();
      allow write: if false;
    }

    // Rate-limit de eventos de seguranÃƒÂ§a: somente backend escreve.
    match /security_events_rate/{uid} {
      allow read, write: if false;
    }

    // Multi-Admin (delegaÃƒÂ§ÃƒÂ£o) usa a coleÃƒÂ§ÃƒÂ£o raiz `usuarios`
    // - leitura: apenas o Painel Master / Admins
    // - update: apenas o Painel Master / Admins
    // - create: somente o prÃƒÂ³prio usuÃƒÂ¡rio
    match /usuarios/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdminPanel());
      allow update: if isAdminPanel();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Galeria de eventos (coleÃƒÂ§ÃƒÂ£o raiz legada) â€” bloqueada; usar igrejas/{id}/eventos.
    match /eventos/{eventoId} {
      allow read: if true;
      allow write: if false;
      match /comentarios/{commentId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Site institucional Ã¢â‚¬â€ leitura pÃƒÂºblica. Galeria `institutional_gallery`: equipe da igreja pode ordenar/upload (painel igreja = master).
    // Outros docs (ex.: `site`) sÃƒÂ³ painel master/adm.
    match /app_public/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdminPanel()
        || (docId == 'institutional_gallery' && canManageChurch());
    }

    // Legado: protocolo na raiz (antes da migraÃƒÂ§ÃƒÂ£o para igrejas/{id}/certificados_emitidos).
    match /certificados_emitidos/{certId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update, delete: if isSignedIn()
        && resource.data.tenantId is string
        && canAccessTenant(resource.data.tenantId)
        && canWriteTenant(resource.data.tenantId);
    }

    // Legado: ÃƒÂ­ndice UUID Ã¢â€ â€™ tenantId na raiz (migraÃƒÂ§ÃƒÂ£o para igrejas/{id}/certificados_protocol_index).
    match /certificados_protocol_index/{certId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.tenantId is string
        && canAccessTenant(request.resource.data.tenantId)
        && canWriteTenant(request.resource.data.tenantId);
      allow update, delete: if false;
    }

    // Legado raiz `pendingUploads` â€” descontinuado; migrar/apagar via Admin SDK (script).
    match /pendingUploads/{docId} {
      allow read, write: if false;
    }

    // `church_aliases` descontinuado â€” SaaS usa sÃ³ `igrejas/{churchId}`.
    match /church_aliases/{aliasId} {
      allow read, write: if false;
    }

    // Logs centralizados de erros multi-tenant (cliente grava; master lÃª).
    match /system_logs/{logId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isMaster();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
