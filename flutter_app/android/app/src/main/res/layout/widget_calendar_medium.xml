<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="horizontal"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.38"
        android:orientation="vertical">

        <TextView
            android:id="@+id/wcm_weekday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="DOMINGO"
            android:textAllCaps="true"
            android:textColor="#FFEF5350"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wcm_day_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="5"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/wcm_today_ev1_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/widget_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/wcm_today_ev1_bar"
                android:layout_width="3dp"
                android:layout_height="24dp"
                android:background="#FF00BCD4" />

            <TextView
                android:id="@+id/wcm_today_ev1_sy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="🚔"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/wcm_today_ev1_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wcm_today_ev1_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#99FFFFFF"
                    android:textSize="8sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/wcm_today_ev2_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/wcm_today_ev2_bar"
                android:layout_width="3dp"
                android:layout_height="24dp"
                android:background="#FF00BCD4" />

            <TextView
                android:id="@+id/wcm_today_ev2_sy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="🚔"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/wcm_today_ev2_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wcm_today_ev2_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#99FFFFFF"
                    android:textSize="8sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/wcm_today_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Sem compromissos hoje"
            android:textAllCaps="true"
            android:textColor="#88FFFFFF"
            android:textSize="9sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:layout_weight="0.62"
        android:orientation="vertical">

        <TextView
            android:id="@+id/wcm_f1_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAllCaps="true"
            android:textColor="#73FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/wcm_f1_ev1_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/widget_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/wcm_f1_ev1_bar"
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="#FF2563EB" />

            <TextView
                android:id="@+id/wcm_f1_ev1_sy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/wcm_f1_ev1_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/wcm_f1_ev2_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/widget_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/wcm_f1_ev2_bar"
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="#FF2563EB" />

            <TextView
                android:id="@+id/wcm_f1_ev2_sy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/wcm_f1_ev2_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/wcm_f2_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAllCaps="true"
            android:textColor="#73FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/wcm_f2_ev1_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/widget_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/wcm_f2_ev1_bar"
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="#FF2563EB" />

            <TextView
                android:id="@+id/wcm_f2_ev1_sy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/wcm_f2_ev1_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/wcm_f3_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAllCaps="true"
            android:textColor="#73FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/wcm_f3_ev1_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/widget_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/wcm_f3_ev1_bar"
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="#FF2563EB" />

            <TextView
                android:id="@+id/wcm_f3_ev1_sy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/wcm_f3_ev1_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
