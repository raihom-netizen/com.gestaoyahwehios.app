<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/widget_scales_label"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/wdb_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/widget_brand_name"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Hoje -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.15"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/wdb_today_weekday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SEGUNDA-FEIRA"
                android:textAllCaps="true"
                android:textColor="#FFFF8A50"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wdb_today_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="29"
                android:textColor="#FFFFFFFF"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wdb_today_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:maxLines="5"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Próximos dias -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/wdb_day1_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/wdb_day1_weekday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TERÇA-FEIRA"
                    android:textAllCaps="true"
                    android:textColor="#99FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wdb_day1_events"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="4"
                    android:textColor="#FFFFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/wdb_day2_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/wdb_day2_weekday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="QUARTA-FEIRA"
                    android:textAllCaps="true"
                    android:textColor="#99FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wdb_day2_events"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="4"
                    android:textColor="#FFFFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/wdb_finance_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#22FF8A50"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💳"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/wdb_finance_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Conta a pagar hoje"
            android:textColor="#FFFFCCBC"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/wdb_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Toque para abrir"
        android:textColor="#66FFFFFF"
        android:textSize="9sp" />
</LinearLayout>
